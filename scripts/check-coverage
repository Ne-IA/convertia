#!/usr/bin/env python3
"""check-coverage - G27 per-domain coverage floors + G28 diff gate + the security-crate branch floor
(P0.4.8). The coverage half of the test-quality plane.

Three tiers:

  STRUCTURAL FREEZE (live NOW): the committed `coverage-floors.toml` policy is pinned — `[meta].diff_floor`
  (G28, == 80) and `[meta].target_line_floor` (the 50->70 ratchet destination) cannot be silently relaxed,
  and the BRANCH_FLOOR_DOMAINS contract (the no-harm/detect kernel that MUST carry a branch floor once it
  lands: crate::detection / crate::fs_guard / crate::isolation) is frozen here. A relaxation reddens the gate
  (an owner-acked L(-1) edit — coverage-floors.toml is in the L(-1) cage, G71).

  INCREASE-ONLY DECREASE-GUARD (live the moment any floor exists): the floors ratchet UP only. A commit
  that LOWERS any [line]/[branch] floor vs the prior committed version FAILS (a raise is a deliberate
  committed change). The prior version is read via `git show <base>:coverage-floors.toml` — `--base`
  (CI passes `github.event.before`); local default HEAD. Fail-OPEN only if no base resolves (the L4 mirror
  with the explicit base is fail-closed), the G8/G70 diff-base posture. Empty floors in P0 => no-op.

  LIVE per-domain / diff tier (WIRED in P1.54): once a coverage report exists, assert EACH domain is >=
  its own floor (NEVER averaged — G27), each BRANCH_FLOOR_DOMAINS crate's branch coverage >= its branch
  floor, and the diff coverage >= diff_floor (G28). Two report shapes feed the two halves:
    * PER-DOMAIN (G27) from the SUMMARY reports — Rust `cargo llvm-cov --json` (RUST_COV, per-file
      lines.percent rolled up per CRATE by summing covered/count) + Vitest v8 `json-summary` (TS_COV,
      per-file pct rolled up into the one `ui` package domain). Roll-up sums covered/count — it is never
      an average of per-file percents (G27).
    * DIFF (G28) from the PER-LINE lcov reports — `cargo llvm-cov --lcov` (RUST_COV_LCOV) + the Vitest
      `lcov` reporter (TS_COV_LCOV): the changed new-side lines in `base..HEAD` that are EXECUTABLE
      PRODUCT lines (present in the lcov DA map) must be >= diff_floor% covered.
  TOOLING is excluded from the floors AND the diff: a Rust file maps to a product crate only if it lives
  under `src-tauri/src/` (convertia-core) or `crates/imgworker/src/` (convertia-imgworker); the `xtask`
  dev-bin + gate scripts are tooling, not product (_rust_domain -> None). BRANCH coverage needs nightly
  (`-Z coverage-options=branch`); the pinned floor is stable, so Rust branch data is ABSENT in P1 (the
  [branch] BRANCH_FLOOR_DOMAINS — crate::detection/fs_guard/isolation — are P2/P3 security-kernel modules
  that land with the nightly branch-coverage run). TS branch coverage (Vitest v8) IS measured but is not
  floored in P1 (no [branch] row). The live tier is skipped-with-notice on a leg with no report.

  BOOT-GLUE DIFF EXEMPTION (G28 only, P2.135 — owner decision A): an `AppHandle`-coupled fn (the launch /
  host glue — the §7.8.1 forward_launch_intake funnel, the single-instance / RunEvent::Opened wiring, the
  AppHandle predicate/buffer shells) CANNOT be reached by `cargo test` execution coverage: it needs a tauri
  runtime, and this crate ships NO `tauri::test` mock harness BY DECISION — the established BOOT-STAGE
  PATTERN tests such glue by SOURCE-SCAN (the fn-pointer signature pins, e.g. launch_intake's
  `launch_funnel_items_have_their_spec_signatures`; production_boot_source) + the §1.6 E2E real-window run +
  the §6.6 walkthrough, NOT by line-execution coverage (test-strategy §1.1a). So the G28 DIFF floor would
  fire "for the wrong reason" on those lines. They are therefore EXCLUDED from the diff floor — identified
  STRUCTURALLY (a fn whose SIGNATURE references an `AppHandle` type — parameter, return or bound, all
  equally runtime-coupled; _apphandle_fn_ranges; NOT a loop-editable marker) and FAIL-CLOSED (a fn whose
  body brace does not balance stays COUNTED). The lines
  remain counted in the G27 per-domain floor (where the crate's headroom absorbs them) — only the
  change-only diff gate, which a concentrated boot-glue diff would uniquely break, exempts them. The set is
  LOGGED every run (no silent exemption). This is a G28 SCOPE refinement, not a floor relaxation: diff_floor
  stays 80 (freeze_floors).

stdlib-only. L(-1) security-critical (matched by scripts/check-*; coverage-floors.toml is L(-1) too).

Usage: check-coverage [--full] [--base <git-ref>]
Exit:  0 = clean (or target-absent); 1 = a violation; 2 = coverage-floors.toml missing/malformed.
"""
from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
import tomllib
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
FLOORS = ROOT / "coverage-floors.toml"

# the no-harm / detect kernel that MUST carry a BRANCH-coverage floor once it lands (a guard rejecting
# `../` but not `..\` is 100% LINE-covered by Unix-only tests yet misses the Windows branch). Frozen here,
# not in the toml (the toml holds only numeric floors). §0.7 crate-module logical names.
BRANCH_FLOOR_DOMAINS = ("crate::detection", "crate::fs_guard", "crate::isolation")
DIFF_FLOOR = 80          # G28 — >= 80% on changed lines
TARGET_LINE_FLOOR = 70   # the 50 -> 70 ratchet destination (informational target)

# the coverage reports the live tier reads (per the §6.7.1 step-3 leg, P1.54). The SUMMARY reports drive
# the per-domain floors (G27); the per-line lcov reports drive the changed-lines diff floor (G28).
RUST_COV = ROOT / "target" / "llvm-cov" / "coverage.json"     # cargo llvm-cov --json (per-domain summary)
TS_COV = ROOT / "coverage" / "coverage-summary.json"          # vitest v8 json-summary (per-domain summary)
RUST_COV_LCOV = ROOT / "target" / "llvm-cov" / "coverage.lcov"  # cargo llvm-cov --lcov (per-line, G28 diff)
TS_COV_LCOV = ROOT / "coverage" / "lcov.info"                   # vitest lcov reporter (per-line, G28 diff)

# the one TS product domain (the WebView UI package; all of src/** rolls up here). Rust product domains
# are the CRATE names, derived from the file path by _rust_domain (tooling -> None).
TS_DOMAIN = "ui"

# the security-kernel module names behind BRANCH_FLOOR_DOMAINS (strip the `crate::` prefix) — used to map
# a Rust file under src-tauri/src/<module>/ to its branch-floor domain. Branch data is nightly-only, so
# this is inert in P1 (the modules are P2/P3 shells); the mapping is ready for when they land.
SECURITY_BRANCH_MODULES = tuple(d.split("::", 1)[1] for d in BRANCH_FLOOR_DOMAINS)

# a unified-diff hunk header: `@@ -a,b +c,d @@` — capture the new-side start (c) + optional length (d).
_HUNK_RE = re.compile(r"^@@ -\d+(?:,\d+)? \+(\d+)(?:,(\d+))? @@")

# the boot-glue diff exemption (G28, P2.135): a fn-signature start + the `AppHandle` parameter type marker.
_FN_RE = re.compile(r"\bfn\s+\w+")
_APPHANDLE_RE = re.compile(r"\bAppHandle\b")


def fail(msg: str) -> None:
    print(f"[G27/G28] FAIL: {msg}", file=sys.stderr)


def _load_floors(path: Path = FLOORS) -> tuple[dict, str | None]:
    if not path.is_file():
        return {}, "missing"
    try:
        return tomllib.loads(path.read_text(encoding="utf-8")), None
    except (tomllib.TOMLDecodeError, UnicodeDecodeError, OSError) as e:
        return {}, f"malformed/unreadable ({e})"


def freeze_floors() -> int:
    """The committed coverage-floors.toml policy is pinned (G27/G28 cannot be silently relaxed)."""
    cfg, err = _load_floors()
    if err == "missing":
        fail("coverage-floors.toml is missing — the coverage-floor contract is not pinned")
        return 2
    if err:
        fail(f"coverage-floors.toml is {err} — the coverage policy cannot be verified")
        return 2
    meta = cfg.get("meta", {})
    problems = 0
    if meta.get("diff_floor") != DIFF_FLOOR:
        fail(f"coverage-floors.toml [meta].diff_floor is {meta.get('diff_floor')!r}, must be {DIFF_FLOOR} "
             f"(the G28 changed-lines floor)")
        problems += 1
    if meta.get("target_line_floor") != TARGET_LINE_FLOOR:
        fail(f"coverage-floors.toml [meta].target_line_floor is {meta.get('target_line_floor')!r}, must be "
             f"{TARGET_LINE_FLOOR} (the 50->70 ratchet destination)")
        problems += 1
    if not BRANCH_FLOOR_DOMAINS:
        fail("the BRANCH_FLOOR_DOMAINS contract is empty — the security-crate branch-floor policy is gone")
        problems += 1
    # every [line]/[branch] floor must be a NUMBER — a retype to a string/bool is silently dropped from
    # _floor_map and would escape the decrease-guard (retype-to-ungate, P0.4.8 G1 P2).
    for kind in ("line", "branch"):
        tbl = cfg.get(kind, {})
        if isinstance(tbl, dict):
            for dom, val in tbl.items():
                if isinstance(val, bool) or not isinstance(val, (int, float)):
                    fail(f"coverage-floors.toml [{kind}].{dom} is {val!r}, not a number — a non-numeric "
                         f"floor is silently dropped from the ratchet (a retype-to-ungate relaxation)")
                    problems += 1
    return problems


def _floor_map(cfg: dict) -> dict[str, float]:
    """The flattened {('line'|'branch')+':'+domain: value} map, for the monotonic decrease comparison."""
    out: dict[str, float] = {}
    for kind in ("line", "branch"):
        tbl = cfg.get(kind, {})
        if isinstance(tbl, dict):
            for dom, val in tbl.items():
                if isinstance(val, (int, float)):
                    out[f"{kind}:{dom}"] = float(val)
    return out


def _prior_floors(base: str) -> dict | None:
    """The coverage-floors.toml as of `base` (git show), or None if it does not resolve (no prior /
    git absent / file not in that ref) — fail-OPEN without a base, the G8/G70 diff-base posture."""
    try:
        r = subprocess.run(["git", "show", f"{base}:coverage-floors.toml"], cwd=str(ROOT),
                           capture_output=True, text=True, encoding="utf-8", errors="replace")
    except OSError:
        return None
    if r.returncode != 0 or not r.stdout.strip():
        return None
    try:
        return tomllib.loads(r.stdout)
    except (tomllib.TOMLDecodeError, ValueError):
        return None


def decrease_guard(base: str | None) -> int:
    """INCREASE-ONLY: a [line]/[branch] floor that DECREASED — or was REMOVED (a key in prior, gone in cur:
    un-gates the domain, equivalent to lowering to nothing) — vs the prior committed version fails (a raise
    is fine). The prior is read via git show. No prior (first landing / no base) or BOTH empty (genuine P0)
    => no-op (fail-open w/o a base, the G8/G70 diff-base posture). A genuinely retired domain's floor is
    dropped in the SAME owner-acked commit that removes the domain (P0.4.8 G1 P2 — removal was a fail-open)."""
    cfg, err = _load_floors()
    if err:
        return 0                                   # freeze_floors already reported it
    cur = _floor_map(cfg)
    refs = [base] if base else ["HEAD"]
    prior_cfg = None
    for ref in refs:
        prior_cfg = _prior_floors(ref)
        if prior_cfg is not None:
            break
    if prior_cfg is None:
        return 0                                   # no prior to compare (first landing / no base) — fail-open
    prior = _floor_map(prior_cfg)
    if not prior and not cur:
        return 0                                   # genuine P0 — both empty, nothing to ratchet yet
    problems = 0
    for key, prev in prior.items():
        if key not in cur:
            fail(f"coverage floor {key!r} was REMOVED (prior {prev}) — an increase-only ratchet cannot drop "
                 f"a floor (it un-gates the domain); retire it only in the owner-acked commit removing the domain")
            problems += 1
        elif cur[key] < prev:
            fail(f"coverage floor {key!r} LOWERED {prev} -> {cur[key]} (increase-only ratchet; a lowering "
                 f"is an owner decision, not a build-loop edit)")
            problems += 1
    return problems


def _read_report(path: Path) -> dict | None:
    if not path.is_file():
        return None
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError, UnicodeDecodeError, ValueError):
        return None


def _rust_domain(path: str) -> str | None:
    """(pure) the PRODUCT crate domain for a Rust source path, or None if it is tooling / non-product.
    A file is product iff it lives under `src-tauri/src/` (convertia-core) or `crates/imgworker/src/`
    (convertia-imgworker); the `xtask` dev-bin, gate fixtures + everything else are tooling — excluded
    from BOTH the per-domain floors and the diff gate (the docstring's tooling-exclusion rule)."""
    p = path.replace("\\", "/")
    if "src-tauri/src/" in p:
        return "convertia-core"
    if "crates/imgworker/src/" in p:
        return "convertia-imgworker"
    return None


def _rust_branch_domain(path: str) -> str | None:
    """(pure) the `crate::<module>` BRANCH-floor domain for a Rust file under one of the security-kernel
    modules (BRANCH_FLOOR_DOMAINS), else None. Inert in P1 (those modules are P2/P3 shells + Rust branch
    data is nightly-only) — ready for when the security kernel + the nightly branch run land."""
    p = path.replace("\\", "/")
    if "src-tauri/src/" not in p:
        return None
    for mod in SECURITY_BRANCH_MODULES:
        if f"src-tauri/src/{mod}/" in p or p.endswith(f"src-tauri/src/{mod}.rs"):
            return f"crate::{mod}"
    return None


def _parse_lcov(text: str) -> dict[str, dict[int, int]]:
    """(pure) {repo-relative-path: {line: max-hit-count}} from the SF/DA records of an lcov report.
    Paths are normalised to forward slashes + made repo-relative (cargo-llvm-cov emits ABSOLUTE SF;
    Vitest emits RELATIVE), so they match `git diff`'s repo-relative paths. TOOLING `.rs` files (a
    None _rust_domain — e.g. xtask) are dropped so the diff gate never holds tooling to the product
    floor; non-`.rs` (TS) files are all product (Vitest already excluded generated/entry/test files)."""
    out: dict[str, dict[int, int]] = {}
    roots = str(ROOT).replace("\\", "/")
    cur: str | None = None
    for raw in text.splitlines():
        if raw.startswith("SF:"):
            p = raw[3:].strip().replace("\\", "/")
            if p.startswith(roots + "/"):
                p = p[len(roots) + 1:]
            if p.endswith(".rs") and _rust_domain(p) is None:
                cur = None                 # tooling Rust file — excluded from the diff gate
            else:
                cur = p
                out.setdefault(cur, {})
        elif raw.startswith("DA:") and cur is not None:
            body = raw[3:].split(",")
            try:
                ln, cnt = int(body[0]), int(body[1])
            except (ValueError, IndexError):
                continue
            out[cur][ln] = max(out[cur].get(ln, 0), cnt)   # covered if ANY record hits the line
        elif raw.startswith("end_of_record"):
            cur = None
    return out


def _changed_lines(base: str) -> dict[str, set[int]] | None:
    """The added/modified NEW-side line numbers per file in `base..HEAD`, or None if the range does not
    resolve (git absent / an all-zeros or unknown base) — fail-OPEN without a base (the G8/G70 diff-base
    posture). Repo-relative forward-slash paths (git's native form)."""
    try:
        # -c core.quotepath=false: show non-ASCII paths literally (UTF-8), unquoted, so the `+++ b/<path>`
        # strip below never sees git's octal-escaped `"b/\xxx"` form. Product paths are ASCII module names
        # (no quote/backslash/control chars, the only remaining quoting triggers), so a `+++` path is never
        # quoted — the diff gate cannot silently miss a changed product file. [Build-Session-Entscheidung: P1.54]
        r = subprocess.run(["git", "-c", "core.quotepath=false", "diff", "--unified=0", "--no-color", base, "HEAD"],
                           cwd=str(ROOT), capture_output=True, text=True, encoding="utf-8", errors="replace")
    except OSError:
        return None
    if r.returncode != 0:
        return None
    out: dict[str, set[int]] = {}
    cur: str | None = None
    for line in r.stdout.splitlines():
        if line.startswith("+++ "):
            path = line[4:].strip()
            if path == "/dev/null":
                cur = None
            else:
                cur = (path[2:] if path.startswith("b/") else path).replace("\\", "/")
                out.setdefault(cur, set())
        elif line.startswith("@@") and cur is not None:
            m = _HUNK_RE.match(line)
            if m:
                start = int(m.group(1))
                length = int(m.group(2)) if m.group(2) else 1
                out[cur].update(range(start, start + length))   # length 0 (pure deletion) => empty
    return out


def _strip_rust(text: str) -> str:
    """(pure) `text` with every COMMENT, STRING, CHAR and RAW-STRING body replaced by spaces (newlines
    preserved), so a `{`/`}`/`(`/`)` inside a `"format {}"`, a `// comment {`, a `/* } */` or a `'{'` char
    literal never miscounts in the brace/paren scan that finds AppHandle-fn bodies (the P2.135 boot-glue
    exemption). SAME LENGTH + same newline positions as the input, so character offsets and line numbers
    map 1:1. Conservative: anything it cannot classify stays as code (the consuming scan is fail-closed —
    an un-found / unbalanced body brace simply does not exempt)."""
    out: list[str] = []
    i, n = 0, len(text)
    while i < n:
        c = text[i]
        if c == "\n":
            out.append("\n"); i += 1
        elif c == "/" and i + 1 < n and text[i + 1] == "/":            # line comment -> EOL
            while i < n and text[i] != "\n":
                out.append(" "); i += 1
        elif c == "/" and i + 1 < n and text[i + 1] == "*":            # block comment (Rust allows NESTING)
            out.append("  "); i += 2; depth = 1
            while i < n and depth > 0:
                if text[i] == "\n":
                    out.append("\n"); i += 1
                elif text[i] == "/" and i + 1 < n and text[i + 1] == "*":
                    out.append("  "); i += 2; depth += 1
                elif text[i] == "*" and i + 1 < n and text[i + 1] == "/":
                    out.append("  "); i += 2; depth -= 1
                else:
                    out.append(" "); i += 1
        elif c == "r" and i + 1 < n and (text[i + 1] == '"' or text[i + 1] == "#"):  # maybe a raw string
            k = i + 1
            while k < n and text[k] == "#":
                k += 1
            if k < n and text[k] == '"':
                hashes = k - (i + 1)                                   # `#`s between the `r` and the `"`
                out.append(" " * (k - i + 1)); i = k + 1
                closer = '"' + "#" * hashes
                while i < n:
                    if text[i] == "\n":
                        out.append("\n"); i += 1
                    elif text.startswith(closer, i):
                        out.append(" " * len(closer)); i += len(closer); break
                    else:
                        out.append(" "); i += 1
            else:                                                       # an ident starting with `r`, not a raw string
                out.append(c); i += 1
        elif c == '"':                                                 # normal string
            out.append(" "); i += 1
            while i < n:
                if text[i] == "\\" and i + 1 < n:
                    out.append(" \n" if text[i + 1] == "\n" else "  "); i += 2
                elif text[i] == '"':
                    out.append(" "); i += 1; break
                elif text[i] == "\n":
                    out.append("\n"); i += 1
                else:
                    out.append(" "); i += 1
        elif c == "'":                                                 # char literal vs lifetime
            if i + 1 < n and text[i + 1] == "\\":                      # escaped char '\n' '\\' '\'' '\u{..}'
                j = i + 2
                while j < n and j < i + 12 and text[j] not in ("'", "\n"):
                    j += 1
                if j < n and text[j] == "'":
                    out.append(" " * (j - i + 1)); i = j + 1
                else:
                    out.append("'"); i += 1
            elif i + 2 < n and text[i + 2] == "'":                     # simple 'X' (incl. '{' '}')
                out.append("   "); i += 3
            else:                                                      # a lifetime 'a — leave as code
                out.append("'"); i += 1
        else:
            out.append(c); i += 1
    return "".join(out)


def _apphandle_fn_ranges(text: str) -> list[tuple[str, int, int]]:
    """(pure) [(fn_name, start_line, end_line)] for each fn whose SIGNATURE references an `AppHandle` type
    (a parameter, a return, or a where-bound — all equally runtime-coupled) — the boot-glue the boot-stage
    pattern (source-scan + §1.6 E2E + §6.6) tests
    instead of cargo-test execution (this crate ships no tauri::test mock harness BY DECISION), so the G28
    diff floor would fire "for the wrong reason" on it (test-strategy §1.1a). Scans `_strip_rust`'d text and
    counts PARENS to find the body-opening `{` (angle brackets are IGNORED, so `-> T`, generics and
    `AppHandle<R>` never miscount), then brace-matches the body. FAIL-CLOSED: a `;`-terminated declaration
    (no body) or a body whose braces do not balance yields NO range — those lines stay COUNTED. The
    signature, not a comment/string mention of AppHandle, must match (the strip guarantees it).
    [owner decision A, P2.135 — the boot-glue diff-coverage exemption]"""
    stripped = _strip_rust(text)
    ranges: list[tuple[str, int, int]] = []
    n = len(stripped)
    for mt in _FN_RE.finditer(stripped):
        name = mt.group().split()[-1]
        i, pdepth, body_open = mt.end(), 0, None
        while i < n:                                   # find the body `{` at paren-depth 0, or a `;` (no body)
            ch = stripped[i]
            if ch == "(":
                pdepth += 1
            elif ch == ")":
                pdepth -= 1
            elif pdepth == 0 and ch == ";":
                break
            elif pdepth == 0 and ch == "{":
                body_open = i; break
            i += 1
        if body_open is None or not _APPHANDLE_RE.search(stripped[mt.start():body_open]):
            continue
        bdepth, j, body_close = 0, body_open, None
        while j < n:                                   # brace-match the body
            ch = stripped[j]
            if ch == "{":
                bdepth += 1
            elif ch == "}":
                bdepth -= 1
                if bdepth == 0:
                    body_close = j; break
            j += 1
        if body_close is None:
            continue                                   # fail-closed: unbalanced body, do not exempt
        ranges.append((name, stripped.count("\n", 0, mt.start()) + 1, stripped.count("\n", 0, body_close) + 1))
    return ranges


def _boot_glue_exempt(changed: dict[str, set[int]]) -> tuple[dict[str, set[int]], list[str]]:
    """{path: exempt-line-set} for the AppHandle-coupled boot-glue fns in the CHANGED product Rust files,
    plus a flat `path::fn` audit-log label list (G28, P2.135). Read from the HEAD working tree (the CI leg
    checks out HEAD, so the diff's new-side line numbers match the on-disk source). A non-product / non-Rust
    / unreadable file contributes nothing — fail-closed, its lines stay counted."""
    exempt: dict[str, set[int]] = {}
    labels: list[str] = []
    for path in changed:
        if not path.endswith(".rs") or _rust_domain(path) is None:
            continue
        try:
            src = (ROOT / path).read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError):
            continue
        lines: set[int] = set()
        for name, start, end in _apphandle_fn_ranges(src):
            lines.update(range(start, end + 1))
            labels.append(f"{path}::{name}")
        if lines:
            exempt[path] = lines
    return exempt, labels


def _diff_counts(changed: dict[str, set[int]], hits: dict[str, dict[int, int]],
                 exempt: dict[str, set[int]] | None = None) -> tuple[int, int]:
    """(pure) (covered, total) over changed lines that are EXECUTABLE PRODUCT lines (present in the
    per-line lcov hit map). A changed line not in the hit map — a non-product file, a comment, a blank
    line, a type-only line — is not counted: the diff gate measures executable product lines only. A
    changed line inside an AppHandle-coupled boot-glue fn (in `exempt`) is ALSO skipped — the boot-stage
    pattern (§1.6 E2E + source-scan) covers it, not cargo-test execution (G28 P2.135 exemption)."""
    covered = total = 0
    for path, lines in changed.items():
        file_hits = hits.get(path)
        if not file_hits:
            continue
        ex = exempt.get(path) if exempt else None
        for ln in lines:
            if ex and ln in ex:
                continue
            if ln in file_hits:
                total += 1
                if file_hits[ln] > 0:
                    covered += 1
    return covered, total


def _diff_verdict(covered: int, total: int, floor: float) -> int:
    """(pure) the G28 changed-lines verdict: 0 problems if there are no changed executable product lines
    (vacuous) or coverage >= floor; 1 if below. Printed either way so the measured value is visible."""
    if total == 0:
        print("[G28] no changed executable product lines in range - diff floor n/a")
        return 0
    pct = covered / total * 100
    print(f"[G28] diff coverage = {pct:.1f}% ({covered}/{total} changed executable product lines covered; "
          f"floor {floor}%)")
    if pct < floor:
        fail(f"diff coverage {pct:.1f}% < floor {floor}% on changed product lines ({covered}/{total})")
        return 1
    return 0


def check_floor(measured: dict[str, float], floors: dict[str, float], kind: str) -> int:
    """(pure) every domain with a floor meets it — NEVER averaged (G27). A measured domain BELOW its floor
    fails; a domain with no floor yet is not gated (its row is added in P1)."""
    problems = 0
    for dom, floor in floors.items():
        if dom in measured and measured[dom] < floor:
            fail(f"{kind} coverage for {dom!r} is {measured[dom]:.1f}% < floor {floor}%")
            problems += 1
    return problems


def run_live(cfg: dict) -> int:
    """LIVE per-domain tier (G27, P1.54): each measured domain's LINE coverage >= its [line] floor + each
    measured security-kernel domain's BRANCH coverage >= its [branch] floor — NEVER averaged. Target-absent
    (skip) on a leg with no summary report. The measured values are printed so the increase-only ratchet
    can be set from the observed CI baseline."""
    if not RUST_COV.is_file() and not TS_COV.is_file():
        print("[G27] no coverage report on this leg (the cargo-llvm-cov / vitest reports are generated on "
              "the Linux Lane-A leg) — per-domain floors skipped (target-absent)")
        return 0
    line_floors = {d: float(v) for d, v in cfg.get("line", {}).items() if isinstance(v, (int, float))}
    branch_floors = {d: float(v) for d, v in cfg.get("branch", {}).items() if isinstance(v, (int, float))}
    measured_line, measured_branch = _extract_measured()
    for dom in sorted(measured_line):
        print(f"[G27] line   {dom} = {measured_line[dom]:.1f}% (floor {line_floors.get(dom, 'none')})")
    for dom in sorted(measured_branch):
        print(f"[G27] branch {dom} = {measured_branch[dom]:.1f}% (floor {branch_floors.get(dom, 'none')})")
    problems = check_floor(measured_line, line_floors, "line") + check_floor(measured_branch, branch_floors, "branch")
    for dom in BRANCH_FLOOR_DOMAINS:
        if dom in measured_branch and dom not in branch_floors:
            fail(f"branch-floor domain {dom!r} is measured but has no [branch] floor in coverage-floors.toml "
                 f"(the security-crate branch-floor contract requires one once the crate lands)")
            problems += 1
    return problems


def _accumulate(acc: dict[str, list[int]], domain: str, covered: int, count: int) -> None:
    """Sum covered/count into acc[domain] = [covered, count] (the roll-up that makes a domain pct a true
    covered/count ratio, NOT an average of per-file percents — G27)."""
    slot = acc.setdefault(domain, [0, 0])
    slot[0] += int(covered)
    slot[1] += int(count)


def _extract_measured() -> tuple[dict[str, float], dict[str, float]]:
    """The measured per-domain LINE / BRANCH percentages from the summary reports. Rust (`cargo llvm-cov
    --json`, LLVM export): per-file `summary.lines`/`summary.branches` rolled up per product CRATE
    (_rust_domain; tooling dropped) + per security-module for branch. TS (Vitest v8 `json-summary`): every
    per-file entry rolled up into the one `ui` package domain. A domain with zero executable units (count
    0) is omitted (an undefined ratio gates nothing) — so a missing report yields {} (target-absent)."""
    line_acc: dict[str, list[int]] = {}
    branch_acc: dict[str, list[int]] = {}

    rust = _read_report(RUST_COV)
    if isinstance(rust, dict):
        for entry in rust.get("data", []):
            for f in entry.get("files", []) if isinstance(entry, dict) else []:
                fn = f.get("filename", "") if isinstance(f, dict) else ""
                summ = f.get("summary", {}) if isinstance(f, dict) else {}
                dom = _rust_domain(fn)
                if dom:
                    ln = summ.get("lines", {})
                    _accumulate(line_acc, dom, ln.get("covered", 0), ln.get("count", 0))
                bdom = _rust_branch_domain(fn)
                if bdom:
                    br = summ.get("branches", {})
                    _accumulate(branch_acc, bdom, br.get("covered", 0), br.get("count", 0))

    ts = _read_report(TS_COV)
    if isinstance(ts, dict):
        for path, summ in ts.items():
            if path == "total" or not isinstance(summ, dict):
                continue
            ln = summ.get("lines", {})
            _accumulate(line_acc, TS_DOMAIN, ln.get("covered", 0), ln.get("total", 0))
            br = summ.get("branches", {})
            _accumulate(branch_acc, TS_DOMAIN, br.get("covered", 0), br.get("total", 0))

    measured_line = {d: c / n * 100 for d, (c, n) in line_acc.items() if n > 0}
    measured_branch = {d: c / n * 100 for d, (c, n) in branch_acc.items() if n > 0}
    return measured_line, measured_branch


def run_diff(cfg: dict, base: str | None) -> int:
    """LIVE diff tier (G28, P1.54): >= diff_floor% coverage on the changed EXECUTABLE PRODUCT lines in
    base..HEAD, read from the per-line lcov reports. Needs BOTH a base AND a per-line report on this leg;
    fail-OPEN otherwise (the report-bearing Linux leg passes --base; the no-report ratchet leg + a missing
    base skip — the G8/G70 diff-base posture)."""
    if base is None:
        return 0
    hits: dict[str, dict[int, int]] = {}
    for p in (RUST_COV_LCOV, TS_COV_LCOV):
        if p.is_file():
            try:
                hits.update(_parse_lcov(p.read_text(encoding="utf-8")))
            except OSError:
                pass
    if not hits:
        return 0                                   # no per-line report on this leg (target-absent)
    changed = _changed_lines(base)
    if changed is None:
        return 0                                   # base did not resolve — fail-open
    exempt, labels = _boot_glue_exempt(changed)    # G28 P2.135: AppHandle boot-glue is source-scan-tested
    if labels:
        n_lines = sum(len(s) for s in exempt.values())
        print(f"[G28] boot-glue exempt: {n_lines} changed line(s) in {len(labels)} AppHandle fn(s) excluded "
              f"from the diff floor (boot-stage pattern, test-strategy 1.1a; still counted in G27): "
              f"{', '.join(sorted(labels))}")
    covered, total = _diff_counts(changed, hits, exempt)
    floor = cfg.get("meta", {}).get("diff_floor", DIFF_FLOOR)
    return _diff_verdict(covered, total, float(floor))


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description="G27/G28 coverage floors + diff gate + branch floor (P0.4.8)")
    ap.add_argument("--full", action="store_true", help="plane parity (the scan is whole-tree either way)")
    ap.add_argument("--base", default=None, help="the prior git ref for the increase-only decrease-guard (CI: github.event.before)")
    args = ap.parse_args(argv)

    structural = freeze_floors()
    if structural >= 2:
        return 2
    cfg, _ = _load_floors()
    total = structural + decrease_guard(args.base) + run_live(cfg) + run_diff(cfg, args.base)
    if total:
        print(f"[G27/G28] {total} coverage-contract violation(s)", file=sys.stderr)
        return 1
    print("[G27/G28] coverage-floor contract OK")
    return 0


if __name__ == "__main__":
    sys.exit(main())
