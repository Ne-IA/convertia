#!/usr/bin/env python3
"""check-fuzz-contract - G48 in-core fuzz-harness layout + G16 per-numeric-IPC-arg overflow contract
(P0.4.3). The in-core untrusted-byte fuzz plane (NOT the isolated engines - those are G26/§6.4.2).

Two tiers, the P0.3.6 / P0.4.1 pattern:

  STRUCTURAL FREEZE (live NOW, no harness needed): the G48 libFuzzer in-core target set, the IPC
  proptest contracts (serde-boundary + the per-numeric-IPC-arg overflow boundary set), the mandatory
  libFuzzer resource bounds, and the deterministic G16 bound-firing fixtures are pinned here as a
  CONTRACT and cannot be silently gutted. The date-pinned nightly (`gate-tools.toml [toolchain]
  fuzz_nightly`) must be `nightly-YYYY-MM-DD`, never a floating bare `+nightly`.

  LIVE (target-absent until P3 lands fuzz/): each libFuzzer target is bound to a REAL artifact -
  fuzz/fuzz_targets/<key>.rs that contains a `fuzz_target!` macro (comment-stripped, per-file, NO
  bare-stem / substring / cross-file masking - the P0.4.1 deny-context lesson); each fixture to a
  committed corpus FILE named by its id; each bound to a committed fuzz config (comment-stripped).
  Skips-with-notice while fuzz/ is absent, fail-closes the moment it lands. The IPC proptest legs
  (serde-boundary, numeric-overflow) land in P2 (tests/, NOT under fuzz/) so their LIVE assertion is
  P2-scoped, not fuzz/-gated; their CONTRACT is frozen here.

stdlib-only. L(-1) security-critical (matched by scripts/check-*).

Usage: check-fuzz-contract [--full]   (--full accepted for wiring parity; the contract scan is identical)
Exit:  0 = contract intact (or target-absent); 1 = a violation; 2 = a pinned config is missing/malformed.
"""
from __future__ import annotations

import argparse
import re
import sys
import tomllib
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
GATE_TOOLS = ROOT / "scripts" / "gate-tools.toml"
FUZZ_DIR = ROOT / "fuzz"
FUZZ_WORKFLOW = ROOT / ".github" / "workflows" / "fuzz.yml"

# --- the frozen G48 libFuzzer in-core target CONTRACT (build-gates §6 G48): untrusted-byte surfaces
#     OUTSIDE the §2.12 boundary, each a `fuzz/fuzz_targets/<key>.rs` libFuzzer target. The BODIES land
#     P3-P9 (the box activation note); the SET is frozen now. (key, spec-§). NOT the isolated engines.
G48_FUZZ_TARGETS = [
    ("detect", "crate::detection content-sniff on a hostile corpus (ZIP/OLE2/gzip/svgz/XML; ratio cap + XXE-off)"),
    ("fs_guard_resolve_identity", "crate::fs_guard::resolve_identity on untrusted PATHs (null/overlong/symlink/.. "
                                  "+ the Windows device/reserved/drive-relative/UNC/trailing classes - re-homed "
                                  "here from is_safe_output by the 2026-07-21 P3.73 P0 ruling: spec 2.3.1 makes "
                                  "THIS the untrusted-path fn; 2.3.3 makes is_safe_output no-clobber-only)"),
    ("fs_guard_is_safe_output", "crate::fs_guard::is_safe_output - the spec-2.3.3 no-clobber verdict over an "
                                "untrusted OUTPUT path (no panic; never Ok(Safe) on an unresolvable/NUL path - "
                                "its fallback is gated on exactly NotFound/NotADirectory; the Windows classes "
                                "belong to resolve_identity per the 2026-07-21 P3.73 P0 ruling)"),
    ("csv_tsv", "the in-core CSV/TSV native engine (§3.5.6 InProcessNative - gigabyte fields, recursive quoting, NUL)"),
    ("zip_slip", "archive-entry-name (zip-slip): central-dir entry names with ../ / absolute / NUL / overlong-UTF-8"),
    ("imgworker_ffi", "the imgworker Rust->FFI surface vs staged libvips/libheif/librsvg, ASAN on (boundary side only)"),
]

# --- per-target dormancy (the 2026-07-21 P3.73 fork ruling, owner-acked): fuzz/ arrives at P3.73 with
#     the FOUR buildable in-core targets; `zip_slip` fuzzes the P7.30 in-core OPC/archive-entry peek
#     (activated by the [TEST] box P7.50.1) and `imgworker_ffi` the P4-filled imgworker FFI surface
#     (activated by P4.35.1, after the P4.83 lib split). Demanding those harnesses before their target
#     fns exist forces a stub anti-pattern (CLAUDE §5), so each late target (+ its fixture) is DORMANT
#     until its ACTIVATING BOX is checked `[x]` in the plan - SELF-HEALING, the plan-lint-check-27
#     philosophy: the check reads the box status live, so the box's own check-off IS the arming event
#     (a checked-off activation box with no harness reds immediately; there is no follow-up L(-1) act
#     to forget). Dormancy waives ABSENCE only: a PRESENT dormant harness is still fully validated,
#     and an unresolvable plan file / box id ARMS the target (fail-closed, never a silent waiver). ---
DORMANT_UNTIL = {
    "zip_slip":      ("docs/plan/P7-office.md", "P7.50.1"),
    "imgworker_ffi": ("docs/plan/P4-engine-framework.md", "P4.35.1"),
}
DORMANT_FIXTURES = {
    "zip_slip_entry": ("docs/plan/P7-office.md", "P7.50.1"),
}


def _box_checked(plan_file: str, box_id: str) -> bool:
    """True = the activating box is `[x]` OR cannot be resolved (a missing plan file / unfindable box
    id must ARM the target - fail-closed, never a silent waiver); False = the box is LEGIBLY not done
    (`[ ]` unchecked or `[!]` blocked - both are provable not-done states, so tolerating the dormant
    absence is semantically correct; only resolution FAILURES arm)."""
    p = ROOT / plan_file
    if not p.is_file():
        return True
    hit = re.search(r"^\s*- \[(x| |!)\] \*\*" + re.escape(box_id) + r"\*\*",
                    p.read_text(encoding="utf-8", errors="replace"), flags=re.M)
    if hit is None:
        return True
    return hit.group(1) == "x"


# --- the G16 IPC proptest contracts: the serde-boundary + the per-numeric-IPC-arg overflow legs land in
#     P2 (P2.126, in tests/ as the C1-C13 commands land - NOT under fuzz/), so their LIVE assertion is
#     P2-scoped, not part of the fuzz/-gated live tier here; the CONTRACT is frozen now. -------------
IPC_PROPTEST_TARGETS = [
    ("ipc_serde", "each #[tauri::command] serde boundary proptested with malformed serde_json -> structured Err (P2)"),
    ("ipc_numeric_overflow", "each numeric IPC arg proptested at the boundary values -> structured Err (P2)"),
]
# the per-numeric-IPC-arg arithmetic-overflow boundary set (G16): every numeric IPC arg is proptested
# against these so a structured Err (never a panic/wrap) is proven at the boundaries.
NUMERIC_OVERFLOW_BOUNDARIES = ["u32::MAX", "i32::MIN", "0", "1", "65535"]  # 2^16-1

# --- the mandatory libFuzzer resource bounds: an OOM/timeout MUST be a committed FINDING, never a
#     silent runner kill. Every fuzz invocation must carry these (+ a G56 timeout-minutes). ----------
LIBFUZZER_BOUNDS = ["-rss_limit_mb", "-max_len", "-timeout", "-max_total_time"]

# --- the deterministic G16 bound-firing fixtures: "no crash" cannot prove a guard is REACHABLE, so each
#     guard gets a committed corpus fixture that MUST fire it. (id, what it proves). -----------------
REQUIRED_FIXTURES = [
    ("nul_path", "a NUL-byte path MUST return Err on every platform (never Ok on a null-byte path - T7+T2a)"),
    ("path_max_plus_1", "a PATH_MAX+1 path MUST return Err (the path-limit guard is reachable)"),
    ("win_device", r"Windows device path (\\.\ , \\?\) MUST return Err on Windows (via resolve_identity - the P3.73 P0 ruling)"),
    ("win_reserved", "Windows reserved name (CON/NUL/COM1-9/LPT1-9 with ANY extension) MUST return Err on Windows (via resolve_identity - the P3.73 P0 ruling)"),
    ("win_drive_relative", "Windows drive-relative (C:foo vs C:\\foo) MUST return Err on Windows (via resolve_identity - the P3.73 P0 ruling)"),
    ("win_unc", r"Windows UNC (\\server\share) MUST return Err on Windows (via resolve_identity - the P3.73 P0 ruling)"),
    ("win_trailing", "Windows trailing dots/spaces MUST return Err on Windows (via resolve_identity - the P3.73 P0 ruling)"),
    ("nul_output_path", "an interior-NUL OUTPUT path MUST return Err from is_safe_output on every platform (its "
                        "non-fallback reject arm - the fallback is gated on exactly NotFound/NotADirectory, so an "
                        "unresolvable target is never Ok(Safe); is_safe_output's OWN bound-firing seed, P3.73 P0 ruling)"),
    ("zip_slip_entry", "a ../../etc/passwd archive-entry-name fixture MUST be rejected (never escapes scratch)"),
]

# --- the fuzz.yml sanitizer POSTURE (the 2026-07-22 owner-ruled G48 refinement; gate-status.md G48
#     entry + the P3.73 rounds-3-6 empirics): Linux = FULL ASAN, macOS = sanitizer-less
#     coverage-guided (`-s none` via the SAN split expression; aarch64-apple-darwin ASAN is
#     upstream-broken under both Apple linkers) + the per-run ASAN re-arm CANARY. Frozen here so a
#     careless workflow edit cannot silently flip the LINUX leg to `-s none` (dropping the only
#     full-ASAN memory-error oracle), smuggle a literal un-split sanitizer value in, or drop the
#     canary (the self-healing re-arm signal). Asserted over the committed fuzz.yml. -------------
SANITIZER_SPLIT_EXPR = "runner.os == 'macOS' && 'none' || 'address'"  # the Linux arm MUST be 'address'
# the sanitizer VALUES that drop the ASAN memory-error oracle (every clap `Sanitizer` variant that is
# not `address`). A DENYLIST, not an allowlist: forbidding these VALUES needs no detection of the
# fuzz invocation, so it cannot be evaded by hiding the `fuzz run` text (e.g. hoisting the subcommand
# into a shell var - the R6-confirm-2 sonnet P1), and it is FP-safe (a `-s`-glued prose substring
# like `dbus -sys stack` yields `ys`, not a forbidden value; a random `grep -s foo` yields `foo`).
# macOS reaches `none` ONLY through the binding-tied `${SAN}` at RUNTIME - never as literal text.
# This set is EXACTLY the non-`address` members of cargo-fuzz 0.13.2's `Sanitizer` ValueEnum
# ({Address,Leak,Memory,Thread,None}; `coverage` is a separate bool, not a `-s` value) - context7-
# verified from source. Any OTHER string is a hard clap rejection (cargo-fuzz errors LOUD), so the
# denylist is complete for the pinned tool. RE-VERIFY on a cargo-fuzz / `fuzz_nightly` pin bump: a
# future release adding a sanitizer variant that runs ASAN-free on Linux would need adding here
# (the G17-r7 pinned-tool-fact discipline).
FORBIDDEN_SANITIZER_VALUES = frozenset({"none", "leak", "memory", "thread"})
CANARY_MARKER = "ASAN healed on aarch64-apple-darwin"  # the canary's ::warning:: re-arm annotation title

# a DATE-pinned nightly: `nightly-YYYY-MM-DD` with a real month/day range (rustup rejects 99-99 too, but
# the gate should not even accept a calendar-impossible date as "pinned").
_NIGHTLY_RE = re.compile(r"nightly-\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\d|3[01])")


def fail(msg: str) -> None:
    print(f"[G48] FAIL: {msg}", file=sys.stderr)


def _strip_rs(text: str) -> str:
    """Rust text with string/raw-string literals + /* */ block + // line comments blanked (strings
    first), so a `fuzz_target!` MENTIONED in a comment OR a string literal does not count as a real
    harness (the P0.4.1 deny-context lesson - bare-token presence is not a real macro invocation)."""
    text = re.sub(r'"(?:\\.|[^"\\])*"', " ", text, flags=re.S)        # regular/byte string literals
    text = re.sub(r'r#*".*?"#*', " ", text, flags=re.S)              # raw strings (approx, over-blanks safe)
    text = re.sub(r"/\*.*?\*/", " ", text, flags=re.S)               # block comments
    return "\n".join(re.sub(r"//.*$", "", ln) for ln in text.split("\n"))  # line comments


# a REAL fuzz_target! is the macro INVOCATION (`fuzz_target!(` or `fuzz_target!{`), not the bare token
# (a string/ident naming it does not define a harness).
_FUZZ_TARGET_RE = re.compile(r"fuzz_target!\s*[({]")


def _strip_cfg(text: str) -> str:
    """Config/script text with `#`- and `//`-comments blanked (toml/sh/yaml use `#`, some use `//`)."""
    return "\n".join(re.sub(r"(#|//).*$", "", ln) for ln in text.split("\n"))


def freeze_contract() -> int:
    """The contract sets must stay non-empty + well-formed (they cannot be silently gutted)."""
    problems = 0
    for name, val in (("G48_FUZZ_TARGETS", G48_FUZZ_TARGETS), ("IPC_PROPTEST_TARGETS", IPC_PROPTEST_TARGETS),
                      ("LIBFUZZER_BOUNDS", LIBFUZZER_BOUNDS), ("REQUIRED_FIXTURES", REQUIRED_FIXTURES),
                      ("NUMERIC_OVERFLOW_BOUNDARIES", NUMERIC_OVERFLOW_BOUNDARIES)):
        if not val:
            fail(f"the {name} contract is empty - the in-core fuzz/overflow policy is gone")
            problems += 1
    keys = {k for k, _ in G48_FUZZ_TARGETS}
    for must in ("detect", "fs_guard_resolve_identity", "csv_tsv"):
        if must not in keys:
            fail(f"G48_FUZZ_TARGETS is missing the mandatory in-core target {must!r}")
            problems += 1
    if "ipc_numeric_overflow" not in {k for k, _ in IPC_PROPTEST_TARGETS}:
        fail("IPC_PROPTEST_TARGETS is missing the per-numeric-IPC-arg overflow proptest")
        problems += 1
    if "|| 'address'" not in SANITIZER_SPLIT_EXPR:
        fail("SANITIZER_SPLIT_EXPR no longer falls back to 'address' - the Linux full-ASAN "
             "guarantee is gone from the frozen posture (the 2026-07-22 G48 refinement)")
        problems += 1
    if "none" not in FORBIDDEN_SANITIZER_VALUES:
        fail("FORBIDDEN_SANITIZER_VALUES no longer forbids `none` - the core silent-ASAN-drop "
             "(a `-s none` sweep) is unguarded")
        problems += 1
    if "address" in FORBIDDEN_SANITIZER_VALUES:
        fail("FORBIDDEN_SANITIZER_VALUES forbids `address` - it would reject the very full-ASAN "
             "leg the posture exists to keep")
        problems += 1
    if not CANARY_MARKER:
        fail("CANARY_MARKER is empty - the ASAN re-arm canary's presence can no longer be asserted")
        problems += 1
    return problems


def freeze_nightly_pin() -> int:
    """The fuzz nightly MUST be DATE-pinned (`nightly-YYYY-MM-DD`), never floating. stdlib tomllib."""
    if not GATE_TOOLS.is_file():
        fail(f"{GATE_TOOLS.name} is missing - the fuzz nightly pin cannot be verified")
        return 2
    try:
        cfg = tomllib.loads(GATE_TOOLS.read_text(encoding="utf-8"))
    except (tomllib.TOMLDecodeError, UnicodeDecodeError, OSError) as e:
        fail(f"{GATE_TOOLS.name} is malformed/unreadable ({e})")
        return 2
    pin = cfg.get("toolchain", {}).get("fuzz_nightly")
    if not pin:
        fail("gate-tools.toml [toolchain] fuzz_nightly is absent - the G48 nightly is not pinned")
        return 1
    if not _NIGHTLY_RE.fullmatch(pin):
        fail(f"fuzz_nightly {pin!r} is not a DATE-pinned `nightly-YYYY-MM-DD` channel (would float)")
        return 1
    return 0


# the `SAN:` env-key definition line (value captured); anchored so `MY_SAN:` never matches.
_SAN_KEY_RE = re.compile(r"^\s*SAN:\s*(.*?)\s*$", re.M)
# every sanitizer-flag VALUE, all clap-reachable spellings: `-s X` / `-s=X` / `-sX` (glued) /
# `--sanitizer X` / `--sanitizer=X`. `(?<!\S)` keeps `-s` from matching inside another token.
# Scanned over the WHOLE comment-stripped file (denylist, no invocation-line detection) so it cannot
# be evaded by hoisting the `fuzz run` subcommand into a shell variable.
_SANITIZER_ARG_RE = re.compile(r"(?<!\S)(?:--sanitizer|-s)(?:[=\s]+|(?=\S))(\S+)")


def _dequote(tok: str) -> str:
    """One matching quote layer stripped (`'none'`/`\"none\"` -> `none`), so a quoted spelling
    cannot slip past the allowlist (the R6-confirm opus bypass)."""
    if len(tok) >= 2 and tok[0] == tok[-1] and tok[0] in "'\"":
        return tok[1:-1]
    return tok


def assert_sanitizer_posture() -> int:
    """The fuzz.yml sanitizer posture (the 2026-07-22 owner-ruled G48 refinement): the committed
    workflow must (1) define the `SAN` env key EXACTLY ONCE, (2) BIND it to the frozen split
    expression whose LINUX arm is 'address' (full ASAN) - binding-tied, not two independent
    substring checks: a redefined `SAN: ${{ 'none' }}` with the frozen string parked in a decoy
    key, or a second rebinding `SAN:` in another step, is caught (the R6-confirm sonnet P1) -,
    (3) pass NO `-s`/`--sanitizer` flag (short/long/glued/`=`/quoted, quote-normalized - the
    R6-confirm opus P2) that resolves to a NON-'address' sanitizer value anywhere in the file - a
    whole-file DENYLIST (never an allowlist scoped to a detected `fuzz run` line, which the
    R6-confirm-2 sonnet P1 evaded by hoisting the subcommand into a shell var): `none`/`leak`/... is
    never a legitimate literal `-s` value in the text, so the scan needs no invocation detection and
    cannot be hidden; macOS reaches `none` only THROUGH the binding-tied `${SAN}` at runtime. (4)
    still contain the ASAN re-arm canary (its ::warning:: marker - the self-healing signal the
    macOS sanitizer-less posture depends on). Target-absent while fuzz.yml does not exist;
    comment-stripped scans (the canary marker lives in an echoed string, scanned raw).

    SCOPE (honest bounds of a static text scan): this proves the cargo-fuzz CLI-flag TEXT. It does
    NOT audit a raw `-Zsanitizer=`/`-Csanitizer=` inside the `RUSTFLAGS` value, nor a sanitizer flag
    hoisted through a shell variable (`SANFLAG='--sanitizer none'; cargo fuzz run … $SANFLAG`) - both
    need deliberate indirection no static shell scan closes (variable/eval/source), NOT an ordinary
    careless edit; every INLINE spelling (short/long, space/`=`/glued, single-/double-quoted,
    real-continuation-split) IS caught."""
    if not FUZZ_WORKFLOW.is_file():
        print("[G48] fuzz.yml absent (the workflow lands with the P3.73 L(-1) tail) - the "
              "sanitizer-posture leg is target-absent; fail-closed the moment it exists")
        return 0
    raw = FUZZ_WORKFLOW.read_text(encoding="utf-8", errors="replace")
    text = _strip_cfg(raw)
    problems = 0
    bindings = _SAN_KEY_RE.findall(text)
    expected = "${{ " + SANITIZER_SPLIT_EXPR + " }}"
    if len(bindings) != 1:
        fail(f"fuzz.yml defines the `SAN` env key {len(bindings)} time(s) - exactly ONE binding is "
             "sanctioned (zero = the split is gone; more = a later definition can silently rebind "
             "the sweep's sanitizer; the 2026-07-22 G48 refinement)")
        problems += 1
    elif bindings[0] != expected:
        fail(f"fuzz.yml binds `SAN:` to {bindings[0]!r} instead of the frozen split {expected!r} - "
             "the Linux leg's full-ASAN posture is no longer structurally pinned (a decoy copy of "
             "the expression elsewhere does not count; the binding is what the sweep resolves)")
        problems += 1
    # collapse shell line-continuations, then DENYLIST every sanitizer flag (whole file - no
    # invocation-line detection to evade) whose resolved value drops ASAN.
    joined = re.sub(r"\\\n\s*", " ", text)
    for hit in _SANITIZER_ARG_RE.finditer(joined):
        val = _dequote(hit.group(1))
        if val in FORBIDDEN_SANITIZER_VALUES:
            fail(f"fuzz.yml passes a sanitizer flag resolving to {val!r} - a non-'address' "
                 "sanitizer drops the ASAN memory-error oracle; only the binding-tied `\"${SAN}\"` "
                 "variable (macOS reaches `none` through it at runtime) or an explicit `address` is "
                 "sanctioned as a literal `-s`/`--sanitizer` value")
            problems += 1
    if CANARY_MARKER not in raw:
        fail(f"fuzz.yml lost the ASAN re-arm canary (marker {CANARY_MARKER!r}) - the macOS "
             "sanitizer-less posture is only sanctioned WITH its self-healing re-arm signal")
        problems += 1
    return problems


def assert_harness_live() -> int:
    """P3: each libFuzzer target bound to a REAL fuzz_target! in its own file; each fixture to a
    committed corpus file; each bound to a comment-stripped fuzz config. NO substring/stem masking."""
    problems = 0

    # 1. each G48 target = a fuzz/fuzz_targets/<key>.rs that contains a real (comment-stripped) fuzz_target!
    targets_dir = FUZZ_DIR / "fuzz_targets"
    for key, desc in G48_FUZZ_TARGETS:
        f = targets_dir / f"{key}.rs"
        if not f.is_file():
            if key in DORMANT_UNTIL and not _box_checked(*DORMANT_UNTIL[key]):
                plan_file, box = DORMANT_UNTIL[key]
                print(f"[G48] target {key!r} DORMANT until its activating box {box} is [x] "
                      f"({plan_file}) - absence tolerated; a present harness is still validated")
                continue
            fail(f"G48 target {key!r} has no fuzz/fuzz_targets/{key}.rs harness ({desc})")
            problems += 1
        elif not _FUZZ_TARGET_RE.search(_strip_rs(f.read_text(encoding="utf-8", errors="replace"))):
            fail(f"fuzz/fuzz_targets/{key}.rs is a hollow stub - no real fuzz_target!(…) invocation ({desc})")
            problems += 1

    # 2. each G16 bound-firing fixture = a committed corpus FILE named by its id (under corpus/ or crashes/)
    corpus_names = {p.name for p in FUZZ_DIR.rglob("*") if p.is_file()}
    for fid, what in REQUIRED_FIXTURES:
        if fid not in corpus_names:
            if fid in DORMANT_FIXTURES and not _box_checked(*DORMANT_FIXTURES[fid]):
                plan_file, box = DORMANT_FIXTURES[fid]
                print(f"[G48] fixture {fid!r} DORMANT until its activating box {box} is [x] "
                      f"({plan_file}) - absence tolerated")
                continue
            fail(f"G16 bound-firing fixture {fid!r} has no committed corpus file ({what})")
            problems += 1

    # 3. the libFuzzer resource bounds are configured in a COMMITTED fuzz config (comment-stripped, so a
    #    bound named only in a comment does not count) - a .toml/.sh/.txt/.yml/.yaml under fuzz/ that the
    #    fuzz invocation reads (auditable/version-controlled, not an ephemeral inline CLI arg).
    cfg_text = "\n".join(_strip_cfg(p.read_text(encoding="utf-8", errors="replace"))
                         for p in FUZZ_DIR.rglob("*")
                         if p.is_file() and p.suffix in (".toml", ".sh", ".txt", ".yml", ".yaml"))
    for bound in LIBFUZZER_BOUNDS:
        if bound not in cfg_text:
            fail(f"libFuzzer bound {bound} is not in a committed fuzz config "
                 f"(an OOM/timeout must be a committed finding, not a runner kill)")
            problems += 1
    return problems


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description="G48 fuzz-harness + G16 overflow contract (P0.4.3)")
    ap.add_argument("--full", action="store_true", help="accepted for wiring parity (scan is identical)")
    ap.parse_args(argv)

    nightly = freeze_nightly_pin()
    if nightly == 2:                                # a missing/malformed pinned config is exit-2
        return 2
    total = freeze_contract() + nightly             # nightly is 0 or 1 here
    total += assert_sanitizer_posture()             # its own target-absent guard (fuzz.yml, not fuzz/)

    if not FUZZ_DIR.is_dir():
        if total:
            print(f"[G48] {total} fuzz-contract violation(s)", file=sys.stderr)
            return 1
        print("[G48] in-core fuzz-harness + overflow contract frozen; no fuzz/ harness yet "
              "(targets land in P3-P9; IPC proptests in P2) - live harness assertion skipped (target-absent)")
        return 0

    total += assert_harness_live()
    if total:
        print(f"[G48] {total} fuzz-contract violation(s)", file=sys.stderr)
        return 1
    print("[G48] in-core fuzz-harness + per-numeric-IPC-arg overflow contract OK")
    return 0


if __name__ == "__main__":
    sys.exit(main())
