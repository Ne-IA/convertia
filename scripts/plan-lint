# check 18: the crash-recovery procedure AND the dual-review divergence-resolution rule must exist in
# build-loop.md, else a "currently absent" annotation could silently survive into the final docs). Each
# procedure pins its HEADER + its load-bearing SUB-RULES, every phrase verified UNIQUE in build-loop.md
# (the P0.6.3 lesson) — so a procedure cannot be gutted to a bare header while staying green. The
# gate-quarantine procedure + the per-finding suppression ledger are authored in §6 (a P0.6.8 reconcile)
# but lie OUTSIDE check 18's named set — the box and build-gates §6 both scope check 18 to these two.
_NAMED_PROCEDURE_PHRASES = (
    "Crash-recovery procedure",       # the §9 procedure header
    "Committed-but-CI-red",           # case (b): a NEW fixing commit, never amend a pushed commit
    "Push is idempotent on retry",    # case (d): a re-push of an already-pushed commit is a safe no-op
    "Divergence-resolution rule",     # the §3 Step 5 rule header
    "the stricter reviewer wins",     # the P0/P1 GO-vs-NOGO -> NOGO core of the divergence rule
)


def doc18_named_procedure(ctx: Ctx) -> list[Finding]:
    """Check 18: the two P0.6-named build-loop procedures — the crash-recovery procedure (§9) and the
    dual-review divergence-resolution rule (§3 Step 5) — exist VERBATIM in build-loop.md as canonical
    phrases (build-gates §6 check 18), each pinned by its header + load-bearing sub-rules so it cannot be
    silently gutted to a bare header. Target-absent until build-loop.md exists (P0.6-authored);
    fail-closed once present (P0.6.8-activated)."""
    return _bl_phrase(ctx, "18:named-procedure", _NAMED_PROCEDURE_PHRASES)


def _extract_fenced_block(text: str, marker: str) -> str | None:
    """The body (the inside lines, joined with '\\n') of the FIRST ``` / ~~~ fenced block whose content
    contains `marker` (case-insensitively), or None if no such block. The inverse of _strip_fenced
    (which drops fenced lines): used to assert a COMMITTED canonical block exists + carries its phrases
    (e.g. the G1 reviewer rubric, P0.6.2). A block that never closes is treated as not-found (fail-closed)."""
    fence = None
    buf: list[str] = []
    for line in _lf(text).split("\n"):
        s = line.lstrip()
        if fence is None:
            if s.startswith("```") or s.startswith("~~~"):
                fence, buf = s[:3], []
            continue
        if s.startswith(fence):                       # the closing fence
            block = "\n".join(buf)
            if marker.lower() in block.lower():
                return block
            fence, buf = None, []
            continue
        buf.append(line)
    return None


# The canonical G1 reviewer-rubric block lives as a fenced block in build-loop.md §3 Step 5 (P0.6.2).
# _RUBRIC_MARKER identifies it; _RUBRIC_PHRASES are the load-bearing strings the box requires present so
# the loop cannot silently under-specify its own review prompt: the five critique dimensions, the
# no-green-by-rewrite test-integrity item, the divergence handling, and the SPEC-CONTRADICTION-above-P0
# class. Matched case-insensitively as substrings WITHIN the extracted block (not the whole doc).
_RUBRIC_MARKER = "ConvertIA dual-review rubric"
_RUBRIC_PHRASES = (
    "STAGED diff",                                     # staged-diff input (not a SHA)
    "COMPLETENESS", "CORRECTNESS", "SPEC-CONFORMANCE", "TEST-INTEGRITY",  # 4 of the 5 critique dimensions
    "open a network surface",                          # the SECURITY dimension's substance — pinned to the
    #   critique line, NOT the bare word "SECURITY" (which collides with "security-critical file" elsewhere
    #   in-block, so renaming the dimension away would slip through — G1 P0.6.2 P3 hardening)
    "SUPPRESSING A REAL REGRESSION",                   # the test-integrity high-scrutiny (no-green-by-rewrite) item
    "convergence/divergence",                          # divergence handling
    "SPEC-CONTRADICTION is a finding CLASS ABOVE P0",  # the unconditional-hard-stop class above P0
)


def doc19_reviewer_rubric(ctx: Ctx) -> list[Finding]:
    """Check 19: the G1 reviewer rubric is a committed, NON-EMPTY fenced block in build-loop.md carrying
    the canonical critique dimensions + the SPEC-CONTRADICTION-above-P0 class + the divergence /
    test-integrity phrases — so the loop cannot silently edit or under-specify its own review prompt
    (P0.6.2). Target-absent until build-loop.md exists (P0.1.3-authored); fail-closed once present."""
    bl = _bl(ctx)
    if not bl:
        return []                          # build-loop.md lands in P0.1.3/P0.6
    F = "docs/process/build-loop.md"
    block = _extract_fenced_block(bl, _RUBRIC_MARKER)
    if block is None or not block.strip():
        return [Finding("19:reviewer-rubric", F, 0,
                        f"the canonical G1 reviewer-rubric fenced block (marker {_RUBRIC_MARKER!r}) is "
                        f"absent or empty — the loop's review prompt is unpinned (P0.6.2)")]
