# --- check 23 (the G68 sibling): the owner-decidable / informational-then-ratcheted gate-status ledger.
# _OWNER_DECIDABLE_GATES is the canonical registry of gates whose required-vs-informational posture is an
# OWNER decision (not a deterministic always-on Gnn). The KEY is matched case-insensitively as a WHOLE
# delimited TOKEN in the ledger row's first column (via _key_binds, so `cargo-acl`/cackle and a back-ticked
# `Kani` bind but a near-miss like `cargo-aclx` does NOT); the VALUE is the effective posture the ledger
# row MUST agree with. INVARIANT: no key may be a substring of another. A flip edits BOTH the ledger row AND this
# map in the SAME owner-acked L(-1) commit — the dual record that makes an informational<->required flip a
# dated, auditable change, never an invisible drift (build-gates §6 check 23). Seeded with the P0.4.5
# over-assurance contracts; later boxes APPEND their gate when authored (P0.5.10 cargo-mutants, P0.7.14 G64,
# P0.7.15 G65, G17b) — each addition rides that box's commit, never a pre-emptive entry for absent code.
_OWNER_DECIDABLE_GATES = {
    "cargo-acl":     "informational",   # cackle dependency-graph capability cap (P0.4.5)
    "kani":          "informational",   # bounded model checking of the numeric caps (P0.4.5)
    "cargo-careful": "informational",   # runtime-UB / extra-assertion nightly wrapper (P0.4.5)
    "cargo-geiger":  "informational",   # unsafe-usage census, informational-forever (P0.4.5)
    "cargo-mutants": "informational",   # scoped mutation testing of the fs_guard/detect/outcome kernel, G15 sub-leg (P0.5.10); owner flips ->required at 0 survived for fs_guard+detect (P3.72 ratchet)
    "g17b":          "informational",   # bundled-engine CVE awareness (osv-scanner/grype over the PURL-keyed engines.lock) (P0.7.7); owner flips ->required via the CVSS>=7-on-an-actively-exercised-section-04-path release-blocking escalation (vuln-response.md / SECURITY.md)
}
_GATE_STATUSES = {"informational", "required", "decided"}
_ISO_DATE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def _is_iso_calendar_date(s: str) -> bool:
    """True iff `s` is a REAL calendar date — strictly stronger than the YYYY-MM-DD SHAPE regex, which
    alone would accept impossible dates like 2026-13-99 / 2026-00-00. Used together with _ISO_DATE (the
    regex enforces the dashed shape; this rejects an out-of-range month/day). Stdlib-only."""
    try:
        datetime.date.fromisoformat(s)
        return True
    except ValueError:
        return False


def _key_binds(key: str, name_lower: str) -> bool:
    """True iff registry `key` appears in `name_lower` as a whole identifier token — delimited by
    start/end or a non-[word-or-hyphen] char — so `cargo-acl` binds the ledger name `` `cargo-acl` / cackle ``
    but NOT a near-miss like `cargo-aclx` or `cargo-acl-ng` (the P0.4.5 G1 P3 substring-footgun fix).
    INVARIANT: no _OWNER_DECIDABLE_GATES key may be a substring of another (cargo-acl / kani /
    cargo-careful / cargo-geiger all satisfy this), and a ledger name must contain the exact key token."""
    return re.search(r"(?<![\w-])" + re.escape(key) + r"(?![\w-])", name_lower) is not None


def _parse_status_rows(text: str) -> list[tuple[str, str, str, int]]:
    """The data rows of the gate-status ledger table — (name_cell, status_lower, since, lineno). The
    ledger table is the markdown table whose header row names BOTH a `Status` and a `Since` column; only
    ITS data rows are parsed (any other table in the doc is ignored). Fence-aware; the all-dashes
    separator row is skipped without ejecting the table."""
    rows: list[tuple[str, str, str, int]] = []
    in_table = False
    for ln, raw in _strip_fenced(text):
        line = raw.strip()
        if not line.startswith("|"):
            in_table = False
            continue
        cells = [c.strip() for c in line.strip("|").split("|")]
        low = [c.lower() for c in cells]
        if "status" in low and "since" in low:        # the ledger header row
            in_table = True
            continue
        if set(line) <= set("|-: "):                  # the header separator row (---|---) — skip, keep table
            continue
        if in_table and len(cells) >= 3:
            rows.append((cells[0], cells[1].lower(), cells[2], ln))
    return rows


def doc23_ratchet_log(ctx: Ctx) -> list[Finding]:
    """Check 23: the owner-decidable / informational-then-ratcheted gate-status decision-log. Every gate
    in _OWNER_DECIDABLE_GATES has a dated, well-formed `docs/process/gate-status.md` ledger row whose
    status AGREES with its effective posture, and every parsed ledger row is itself well-formed — so a
    posture flip is a dated committed line, never an invisible informational<->required change
    (build-gates §6 check 23 / the G68 sibling). Target-absent: skips while the ledger is unauthored (it
    lands in P0.4.5), fail-closed once it exists."""
    F = "docs/process/gate-status.md"
    text = ctx.docs.get(F, "")
    if not text:
        return []                          # the ledger lands in P0.4.5; the check fail-closes once present
    out: list[Finding] = []
    rows = _parse_status_rows(text)
    # (1) every parsed row is well-formed — no malformed status / non-ISO date may hide in the ledger
    for name, status, since, ln in rows:
        if status not in _GATE_STATUSES:
            out.append(Finding("23:ratchet-log", F, ln,
                               f"ledger row {name!r}: status {status!r} is not one of {sorted(_GATE_STATUSES)}"))
        if not _ISO_DATE.match(since) or not _is_iso_calendar_date(since):
            out.append(Finding("23:ratchet-log", F, ln,
                               f"ledger row {name!r}: 'Since' {since!r} is not a valid ISO YYYY-MM-DD date"))
    # (2) every registered owner-decidable gate has a row whose status agrees with the effective posture
    for key, expected in _OWNER_DECIDABLE_GATES.items():
        matches = [r for r in rows if _key_binds(key, r[0].lower())]
        if not matches:
            out.append(Finding("23:ratchet-log", F, 0,
                               f"owner-decidable gate {key!r} has no dated status row "
                               f"(plan-lint check 23 / P1.62.10)"))
            continue
        for name, status, since, ln in matches:
            if status in _GATE_STATUSES and status != expected:
                out.append(Finding("23:ratchet-log", F, ln,
                                   f"ledger row {name!r}: status {status!r} disagrees with the effective "
                                   f"posture {expected!r} — a flip must edit BOTH the ledger row AND the "
                                   f"check-23 _OWNER_DECIDABLE_GATES posture map in the same commit"))
    return out


def doc24_p0_completion(ctx: Ctx) -> list[Finding]:
    """Check 24: docs/process/p0-completion.md run_url: matches the immutable Actions-run URL pattern."""
    p0c = ctx.docs.get("docs/process/p0-completion.md", "")
    if not p0c:
        return []                          # p0-completion.md is written at P0 completion
    out = []
    m = re.search(r"run_url:\s*(\S+)", p0c)
    if m and not re.match(r"https://github\.com/Ne-IA/convertia/actions/runs/\d+\b", m.group(1)):
        out.append(Finding("24:p0-completion-record", "docs/process/p0-completion.md", 0,
                           f"run_url {m.group(1)!r} does not match https://github.com/Ne-IA/convertia/actions/runs/<id>"))
    return out


# --- check 26 (G69): structural-map integrity — the §1a map <-> on-disk tree <-> §0.7 bind ---------
# The map and the §0.7 physical tree are ASCII tree-art fenced blocks (├──/│/└── + → or # annotations,
# variable connector width). _parse_tree_dirs reconstructs the repo-relative DIR set from one such block
# using a width-agnostic indent STACK (the parent of a line is the nearest shallower-indented dir), and
# additionally mines sibling dirs on one line (`a/  b/  c/`) and ancestor dirs implied by an embedded
# path (`lib/ipc/x.ts` -> lib, lib/ipc). Files are ignored; only directories are asserted.
_STRUCT_IGNORE = {"target", "node_modules", "dist", ".git"}   # the committed out-of-scope-tree ignore set
_TREE_CHARS = "│├└─ \t"
_NAME_TOKEN = re.compile(r"^[A-Za-z0-9._\-/]+/?$")
_ANNOT_DELIM = re.compile(r"[→#(]")   # §1a annotates with →, §0.7 with #, and '(' opens a parenthetical


def _name_tokens(stripped: str) -> list[str]:
    """The path-name tokens of a tree line's NODE portion — everything LEFT of the first annotation
    delimiter (→ / # / '('), so trailing prose can never contribute phantom dirs (the G1 r1 hardening).
    Stops at the first token that is not a path name."""
    head = _ANNOT_DELIM.split(stripped, 1)[0]
    out = []
    for tok in head.split():
        if not _NAME_TOKEN.match(tok):
            break
        out.append(tok)
    return out


def _parse_tree_dirs(block_lines: list[str]) -> set[str]:
    """Repo-relative DIR paths named in a tree-art block. The single indent-0 line (convertia/) is the
    repo root (path ''); its descendants are mapped relative to it. Width-agnostic (an indent STACK, not
    a fixed unit). Handles same-line sibling dirs and embedded-path ancestor dirs."""
    stack: list[tuple[int, str]] = []        # (indent, dir-path) parent chain
    dirs: set[str] = set()
    for raw in block_lines:
        stripped = raw.lstrip(_TREE_CHARS)
        if not stripped:
            continue
        indent = len(raw) - len(stripped)
        tokens = _name_tokens(stripped)
        if not tokens:
            continue
        while stack and stack[-1][0] >= indent:
            stack.pop()
        parent = stack[-1][1] if stack else ""
        if indent == 0:                      # the repo-root line (convertia/) — not a mapped subdir
            stack.append((0, ""))
            continue
        for j, tok in enumerate(tokens):
            is_dir = tok.endswith("/")
            segs = [s for s in tok.strip("/").split("/") if s]
            if not segs:
                continue
            if j == 0:                       # the tree NODE — mine its embedded-path ancestor dirs
                cur = parent
                for k, s in enumerate(segs):
                    cur = f"{cur}/{s}" if cur else s
                    if k < len(segs) - 1 or is_dir:   # an intermediate path segment, or a final dir segment
                        dirs.add(cur)
            elif is_dir and len(segs) == 1:  # a same-line sibling — only a SIMPLE dir token, never an embedded path
                dirs.add(f"{parent}/{segs[0]}" if parent else segs[0])
        if tokens[0].endswith("/"):          # deeper following lines nest under the first token's dir
            push = parent
            for s in (s for s in tokens[0].strip("/").split("/") if s):
                push = f"{push}/{s}" if push else s
            stack.append((indent, push))
    return dirs


def _fenced_block_after(text: str, header_re: re.Pattern) -> list[str] | None:
    """The lines of the first ``` / ~~~ fenced block AFTER the first line matching header_re (None if
    no header or no fence)."""
    lines = text.split("\n")
    hdr = next((i for i, ln in enumerate(lines) if header_re.search(ln)), None)
    if hdr is None:
        return None
    j = hdr + 1
    while j < len(lines) and not lines[j].lstrip().startswith(("```", "~~~")):
        j += 1
    if j >= len(lines):
        return None
    fence = lines[j].lstrip()[:3]
    start = j + 1
    k = start
    while k < len(lines) and not lines[k].lstrip().startswith(fence):
        k += 1
    return lines[start:k]


def _section_text(text: str, header_re: re.Pattern) -> str:
    """The text of the section opened by the first line matching header_re, up to the next heading of
    the same or higher level ('' if no such header)."""
    lines = text.split("\n")
    start = next((i for i, ln in enumerate(lines) if header_re.search(ln)), None)
    if start is None:
        return ""
    hm = re.match(r"^(#{1,6})", lines[start])
    level = len(hm.group(1)) if hm else 2
    end = len(lines)
    for j in range(start + 1, len(lines)):
        h = re.match(r"^(#{1,6})\s", lines[j])
        if h and len(h.group(1)) <= level:
            end = j
            break
    return "\n".join(lines[start:end])


def _dirs_from_files(files: list[str]) -> set[str]:
    """Every ancestor dir of a tracked-file path (minus the out-of-scope top-level trees)."""
    dirs: set[str] = set()
    for f in files:
        parts = [p for p in f.replace("\\", "/").split("/") if p]
        for i in range(1, len(parts)):
            d = "/".join(parts[:i])
            if d.split("/")[0] not in _STRUCT_IGNORE:
                dirs.add(d)
    return dirs


def _git_tracked_dirs(root: Path) -> set[str] | None:
    """The on-disk DIR set from `git ls-files` (tracked files only, so untracked scratch never
    false-fails). Uses `-c core.quotepath=false -z` so non-ASCII / space-bearing paths arrive as raw
    UTF-8 with no octal-escaping or quoting (no mangled dir names). None if git is unavailable / errors
    (the caller fails closed)."""
    try:
        r = subprocess.run(["git", "-c", "core.quotepath=false", "ls-files", "-z"],
                           cwd=str(root), capture_output=True, text=True)
    except OSError:
        return None
    if r.returncode != 0:
        return None
    return _dirs_from_files([f for f in r.stdout.split("\0") if f])


def _struct_map_relations(map_dirs: set[str], disk_dirs: set[str], spec07_dirs: set[str]) -> list[tuple[str, str]]:
    """The three bidirectional/projection violations as (kind, dir) tuples — pure, set-only (testable
    without git or the filesystem)."""
    out = []
    out += [("disk-not-in-map", d) for d in sorted(disk_dirs - map_dirs)]
    out += [("map-not-on-disk", d) for d in sorted(map_dirs - disk_dirs)]
    out += [("map-not-in-spec07", d) for d in sorted(map_dirs - spec07_dirs)]
    return out


_STRUCT_MSG = {
    "disk-not-in-map": "on-disk tracked dir '{d}' is absent from the CLAUDE.md §1a Repo-layout map "
                       "(a folder exists with no map row — add it to §1a, and to spec §0.7 if missing)",
    "map-not-on-disk": "the §1a map names '{d}' which is not a tracked on-disk dir (stale map entry — "
                       "remove it, or the dir is empty/untracked)",
    "map-not-in-spec07": "the §1a map names '{d}' which the spec §0.7 physical tree does not home (§1a "
                         "may not invent a dir §0.7 lacks — the projection bind; §0.7 is the higher "
                         "source, so fix §0.7 + §1a together)",
}


def doc26_struct_map(ctx: Ctx) -> list[Finding]:
    """Check 26 (G69): the CLAUDE.md §1a Repo-layout map is BIDIRECTIONAL with the on-disk tree AND a
    faithful projection of spec §0.7. **→ activated in P1:** the §1a map is the P1.64 PLACEHOLDER stub
    until P1-end, so this SKIPS while the §1a section still carries 'PLACEHOLDER' (tolerant of the
    interim docs/ + assets/ dirs) and fail-closes the moment the authoritative map lands. Once active:
    (1) every git-tracked on-disk dir is in the map (a folder with no map row fails); (2) every mapped
    dir is a tracked on-disk dir (a stale map entry fails); (3) every mapped dir is in the §0.7 physical
    tree (the projection bind — §1a may not invent a dir §0.7 does not home). A missing/unparseable map
    or §0.7 block, or an unavailable git, fails CLOSED (never a silent skip once active). The skip
    signal is 'PLACEHOLDER' WITHIN the §1a section only (not a whole-file scan), so a provenance mention
    of 'P1.64' elsewhere in CLAUDE.md cannot keep the gate permanently dormant after P1.64."""
    claude = ctx.docs.get("CLAUDE.md", "")
    sec1a = _section_text(claude, re.compile(r"^#{1,6}\s+1a\b"))
    if not sec1a or "PLACEHOLDER" in sec1a:
        return []                            # §1a is still the placeholder stub -> skip (→ activated in P1)
    map_block = _fenced_block_after(claude, re.compile(r"^#{1,6}\s+1a\b"))
    if map_block is None:
        return [Finding("26:struct-map", "CLAUDE.md", 0,
                        "the §1a Repo-layout map fenced block is absent/unparseable but the placeholder "
                        "marker is gone — fail-closed")]
    arch = ctx.docs.get("docs/spec/00-architecture.md", "")
    spec_block = _fenced_block_after(arch, re.compile(r"^#{1,6}.*Physical tree"))
    if spec_block is None:
        return [Finding("26:struct-map", "docs/spec/00-architecture.md", 0,
                        "the §0.7 Physical tree fenced block is absent/unparseable — cannot run the "
                        "projection bind (fail-closed)")]
    disk_dirs = _git_tracked_dirs(ctx.root)
    if disk_dirs is None:
        return [Finding("26:struct-map", ".", 0,
                        "git ls-files failed — cannot derive the on-disk dir set (fail-closed)")]
    map_dirs = _parse_tree_dirs(map_block)
    spec07_dirs = _parse_tree_dirs(spec_block)
    return [Finding("26:struct-map", "CLAUDE.md", 0, _STRUCT_MSG[kind].format(d=d))
            for kind, d in _struct_map_relations(map_dirs, disk_dirs, spec07_dirs)]


# =============================================================================================
#  Check registry — FORMAT checks live; doc checks 1..26 added incrementally (P0.3.5).
# =============================================================================================
FORMAT_CHECKS = {
    "format:box-parse-completeness": fmt_box_parse_completeness,
    "format:marker-validity": fmt_marker_validity,
    "format:tag-validity": fmt_tag_validity,
    "format:header-well-formedness": fmt_header_well_formedness,
    "format:reference-resolution": fmt_reference_resolution,
    "format:needs-targets-exist-and-acyclic": fmt_needs_targets,
    "format:annotation-pairing": fmt_annotation_pairing,
    "format:sub-box-consistency": fmt_sub_box_consistency,
    "format:numbering-gap-free": fmt_numbering_gap_free,
}
DOC_CHECKS = {
    "2:cross-reference-validity": doc2_cross_reference,
    "3:heading-hierarchy": doc3_heading_hierarchy,
    "4:numbering-gap-free": doc4_numbering_gap_free,
    "21:t2-taint-xor": doc21_taint_xor,
    "5:gate-catalogue-integrity": doc5_gate_catalogue,
    "6:forbidden-tokens": doc6_forbidden_tokens,
    "17:forward-idea-status": doc17_forward_idea_status,
    "8:threat-map-parity": doc8_threat_parity,
    "9:inventory-parity": doc9_inventory_parity,
    "11:span-bound-currency": doc11_span_bound,
    "16:planted-positive-coverage": doc16_planted_positive,
    "22:gate-id-gap-freeness": doc22_gate_id_gap_free,
    "25:doc-graph": doc25_doc_graph,
