    "20:reviewer-family": doc20_reviewer_family,
    "23:ratchet-log": doc23_ratchet_log,
    "24:p0-completion-record": doc24_p0_completion,
    "26:struct-map": doc26_struct_map,
}
CHECKS = {**FORMAT_CHECKS, **DOC_CHECKS}   # remaining doc checks 1..26 inserted as built


def run(ctx: Ctx, only: str | None = None, max_per_check: int | None = None) -> list[Finding]:
    findings: list[Finding] = []
    for cid, fn in CHECKS.items():
        if only and cid != only:
            continue
        fs = fn(ctx)
        findings.extend(fs[:max_per_check] if max_per_check else fs)
    return findings


def load_docs(root: Path) -> dict[str, str]:
    """The doc-wide set: root CLAUDE.md/README.md + every .md under docs/ (relpath -> text)."""
    docs: dict[str, str] = {}
    for top in ("CLAUDE.md", "README.md"):
        f = root / top
        if f.is_file():
            docs[top] = f.read_text(encoding="utf-8", errors="replace")
    dd = root / "docs"
    if dd.is_dir():
        for f in sorted(dd.rglob("*.md")):
            docs[str(f.relative_to(root)).replace("\\", "/")] = f.read_text(encoding="utf-8", errors="replace")
    return docs


def _strip_fenced(text: str) -> list[tuple[int, str]]:
    """(lineno, line) for lines OUTSIDE ``` / ~~~ fenced code blocks (so a `#` comment in a code
    sample is not read as a heading)."""
    out, fence = [], None
    for i, line in enumerate(text.splitlines()):
        s = line.lstrip()
        if fence is None and (s.startswith("```") or s.startswith("~~~")):
            fence = s[:3]
            continue
        if fence is not None:
            if s.startswith(fence):
                fence = None
            continue
        out.append((i + 1, line))
    return out


def build_ctx(root: Path) -> Ctx:
    boxes, by_id, files = load_plan(root)
    return Ctx(root=root, boxes=boxes, by_id=by_id, plan_files=files,
               docs=load_docs(root), gate_ids=_gate_ids(root))


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description="plan-lint / spec-lint doc-consistency gate (G7/G20)")
    ap.add_argument("--check", default=None, help="run only this check id")
    ap.add_argument("--json", action="store_true")
    ap.add_argument("--quiet", action="store_true")
    ap.add_argument("--max-per-check", type=int, default=None)
    ap.add_argument("--root", type=Path, default=ROOT)
    args = ap.parse_args(argv)

    if args.check and args.check not in CHECKS:
        print(f"[plan-lint] unknown check id: {args.check}", file=sys.stderr)
        return 2
    ctx = build_ctx(args.root)
    if not ctx.boxes:
        print("[plan-lint] no plan boxes found (docs/plan/P*.md) — target missing", file=sys.stderr)
        return 2

    findings = run(ctx, only=args.check, max_per_check=args.max_per_check)
    if args.json:
        print(json.dumps([f.__dict__ for f in findings], indent=2))
    elif not args.quiet:
        for f in findings:
            print(f"[plan-lint] {f.check}  {f.file}:{f.lineno}  {f.msg}", file=sys.stderr)
    if findings:
        if not args.quiet:
            print(f"[plan-lint] {len(findings)} finding(s) across {len(ctx.boxes)} boxes", file=sys.stderr)
        return 1
    if not args.quiet:
        print(f"[plan-lint] OK — {len(ctx.boxes)} boxes, {len(CHECKS)} checks clean")
    return 0


if __name__ == "__main__":
    sys.exit(main())
