#!/usr/bin/env python3
"""check-supply-chain - G18 / G18a / G18b structural growth-guard (P0.3.6).

The cargo-deny `deny.toml` and the cargo-vet `supply-chain/` config are the one place the supply-chain
policy could be silently WEAKENED (a forbidden HTTP-client un-denied, a copyleft license allow-listed,
`yanked` downgraded, an import source dropped below the >=2 floor, an exemption added without review).
So the policy INTENT is FROZEN here (a stdlib TOML parse — no cargo-deny/cargo-vet binary needed):

  * deny.toml `[bans].deny` MUST still name every forbidden crate (updater + the HTTP-client family);
  * deny.toml `[licenses].allow` may contain ONLY the frozen permissive set (any copyleft/non-commercial
    or unvetted license is flagged), and it is allow-list-only (cargo-deny v2) so everything unlisted/
    low-confidence is fail-closed denied;
  * deny.toml `[advisories]` is v2 with `yanked = "deny"`; its `ignore` set MUST equal the cargo-audit
    ignore set (the G18 two-scanner reconciliation - no advisory silenced in one tool but live in the other);
  * deny.toml `[sources]` denies unknown registry/git and allow-lists crates.io;
  * deny.toml `[graph].targets` equals the SHIPPED desktop-triple set (EXPECTED_GRAPH_TARGETS) - no scope
    WIDENING that re-masks a banned mobile-only dep into the eval graph, no NARROWING that blinds a
    shipped triple to a real network/copyleft dep - AND `[graph].all-features` stays `true` (off would
    let a banned crate reachable only via a non-default feature escape the [bans] eval);
  * supply-chain/config.toml declares >= 2 distinct import sources (one compromised audit DB cannot
    single-handedly vouch a crate) and its cargo-vet exemption set is growth-guarded (<= the frozen count);
  * the §0.10 tauri-plugin allowlist holds over Cargo.lock — every `tauri-plugin-*` is on the granted
    allowlist OR the forced-transitive-inert set {fs}. This is the **2nd, independent structural
    presence-enforcer** of the deny-all-except rule (beside plan-lint check 13; needs no cargo binary);
    the `.plugin()`-registration surface is plan-lint check 13's (it reads `src-tauri/src`) and the fs:
    capability surface is G47's — this scan guards LOCK PRESENCE only.

Growing/relaxing any of these means editing the frozen expectation in THIS file - itself L(-1)
(scripts/l-neg1-files.toml, G71), so the change carries the owner-ack + a Dual-Review note. The LIVE
`cargo deny check` / `cargo vet check --locked` run in P1 once the workspace Cargo.lock exists (this
gate skips them with a notice until then - the target-absent P0 posture). stdlib-only (tomllib).

Exit: 0 = the policy matches the frozen expectation (+ live checks pass or are target-absent);
      1 = drift / a relaxation; 2 = a config file is missing or unparseable.
"""
from __future__ import annotations

import os
import re
import shutil
import subprocess
import sys
import tomllib
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
DENY = ROOT / "deny.toml"
VET_CONFIG = ROOT / "supply-chain" / "config.toml"
VET_IMPORTS = ROOT / "supply-chain" / "imports.lock"
AUDIT_TOML = ROOT / "audit.toml"           # cargo-audit ignore config (G17; may not exist yet)
# the workspace manifest/lock may sit at the repo root OR under src-tauri/ (spec §0.7 leaves it "root
# OR member" until P1) - search BOTH so the live tier can never be silently disarmed by a layout the
# hard-coded path missed (a Cargo.toml-without-lock FAILS rather than skipping; see _workspace_state).
CARGO_LOCK_CANDIDATES = (ROOT / "Cargo.lock", ROOT / "src-tauri" / "Cargo.lock")
CARGO_TOML_CANDIDATES = (ROOT / "Cargo.toml", ROOT / "src-tauri" / "Cargo.toml")

# P1.59: the live tier invokes `cargo deny check`, which resolves the `cargo-deny` SUBCOMMAND binary via
# PATH. Prepend the pinned, checksum-verified .gate-tools/bin (install-gate-tools' dest) so cargo finds it
# regardless of the ambient PATH - the same self-contained pinned-tool resolution check-sast/
# check-editorconfig use. No-op when the dir is absent (a toolchain-light plane - the live tier then
# skips-with-notice as before).
_GATE_BIN = ROOT / ".gate-tools" / "bin"
if _GATE_BIN.is_dir():
    os.environ["PATH"] = str(_GATE_BIN) + os.pathsep + os.environ.get("PATH", "")

# --- frozen policy expectations (a change here is an L(-1) edit + a Co-Pilot review item) -----------
# every forbidden crate that MUST stay on deny.toml [bans].deny (un-denying one re-opens the egress surface)
FORBIDDEN_CRATES = {
    "tauri-plugin-updater", "tauri-plugin-http",
    "reqwest", "ureq", "hyper", "isahc", "curl", "curl-sys",
}
# the §0.10-granted tauri-plugin allowlist — every `tauri-plugin-*` in Cargo.lock must be on this set OR
# the forced-transitive-inert set below; the LIVE presence-scan `_tauri_plugin_checks` (the 2nd enforcer
# beside plan-lint check 13) asserts it. These five are deliberately Rust-side-only (no fs/http/etc.).
TAURI_PLUGIN_ALLOWLIST = {"single-instance", "dialog", "opener", "store", "log"}
# forced-transitive-INERT plugins: dragged into the closure by a granted plugin but never a surface.
# tauri-plugin-fs is a mandatory transitive dep of tauri-plugin-dialog (re-exports tauri_plugin_fs::FilePath
# + uses FsExt) — a TYPE library only; §0.10 grants the WebView NO fs plugin. Its `.plugin()`-registration is
# forbidden by plan-lint check 13 (reads src-tauri/src); its fs: capability by G47. This scan guards LOCK
# PRESENCE only, so fs is allowed here.
TAURI_PLUGIN_INERT = {"fs"}
# the FROZEN permissive license allow-set: deny.toml [licenses].allow may contain ONLY these. Any other
# license is flagged - every copyleft / network-copyleft / non-commercial family (GPL/AGPL/LGPL/EUPL/
# OSL/CDDL/EPL/SSPL/CC-BY-NC) AND any unvetted permissive one - so a new entry forces a vetted addition
# HERE (L(-1)) with a note. More robust than a copyleft denylist, which can always miss a family.
EXPECTED_LICENSE_ALLOW = frozenset({
    "MIT", "Apache-2.0", "Apache-2.0 WITH LLVM-exception", "BSD-2-Clause", "BSD-3-Clause",
    "ISC", "Unicode-3.0", "Unicode-DFS-2016", "Zlib", "CC0-1.0", "MPL-2.0",
})
# the FOUR desktop release triples ConvertIA ships (spec §03 "Target triples": Win x64 + macOS
# universal {x86_64,aarch64} + Linux x64; Windows-ARM / Linux-musl are [DEFER], not v1). deny.toml's
# [graph].targets MUST equal this set: a SUPERSET (a non-shipped triple, e.g. android) re-masks tauri's
# mobile-only reqwest/hyper back INTO scope (spurious fail) AND a SUBSET (a shipped triple dropped)
# BLINDS the live cargo-deny to a real on-that-triple network/copyleft dep (fail-OPEN). Frozen here so
# the security-load-bearing [graph] scope cannot drift silently — an edit is an L(-1) review item with a
# box-id + Dual-Review note, exactly like FORBIDDEN_CRATES. The egress guarantee does not rest on this
# scope (G29 rule (g)/(j) ban std/tokio/libc sockets in first-party source); this freeze keeps the
# cargo-deny EVALUATION graph equal to the SHIPPED graph.
EXPECTED_GRAPH_TARGETS = frozenset({
    "x86_64-pc-windows-msvc",
    "x86_64-apple-darwin",
    "aarch64-apple-darwin",
    "x86_64-unknown-linux-gnu",
})
MIN_IMPORT_SOURCES = 2          # >=2 distinct audit DBs (Mozilla + Google baseline)
MIN_CONFIDENCE = 0.8            # the license-detection confidence floor (we ship 0.93)
EXPECTED_EXEMPTION_COUNT = 0    # cargo-vet exemptions accepted; a bump is reviewed HERE with a box-id

# §0.8 pinned-floor (P1.59): the load-bearing crates ConvertIA's OWN code relies on at a known API floor.
# Each MUST be PRESENT in Cargo.lock at >= its floor, so a drift below a relied-upon API surface fails
# HERE (deterministically) rather than as an opaque compile break later. Only crates ALREADY in the lock
# are listed; the rest the box names (csv §1.5, chardetng §1.2, process-wrap §1.7, landlock §2.0; the
# librsvg >=2.56.3 floor is a C-library binding, not a Cargo crate) activate when their phase adds them -
# adding a row is the normal growth, lowering a floor is an L(-1) review item. Pre-release floors compare
# by semver precedence (2.0.0 > 2.0.0-rc.25 > 2.0.0-rc.2). [Build-Session-Entscheidung: P1.59 - reconcile
# to the present §0.8 deps; grow as P3/P4 land the rest.]
PINNED_FLOORS = {
    "tauri-specta": "2.0.0-rc.25",   # §0.4.5 IPC codegen (exact pin - the bindings.ts surface)
    "specta":       "2.0.0-rc.25",   # §0.4.5 type introspection (coupled to tauri-specta)
    "walkdir":      "2.5.0",         # §1.1 recursive intake (in the lock now; a direct dep from P3)
    "tempfile":     "3.27.0",        # §0.8 owned-scratch atomic write (in the lock via dev-deps now)
}


def fail(msg: str) -> None:
    print(f"[G18] FAIL: {msg}", file=sys.stderr)


def _ignore_set(advisories: object) -> set[str]:
    """The advisory ids in an `[advisories].ignore` / cargo-audit `[advisories].ignore` list."""
    ig = advisories.get("ignore") if isinstance(advisories, dict) else None
    out: set[str] = set()
    for e in ig or []:
        if isinstance(e, str):
            out.add(e)
        elif isinstance(e, dict) and isinstance(e.get("id"), str):
            out.add(e["id"])
    return out


def _graph_targets(cfg: object) -> set[str]:
    """The set of target TRIPLES declared in deny.toml `[graph].targets`, robust to BOTH cargo-deny v2
    entry forms: a plain triple string OR a `{ triple = "...", features = [...] }` table. Used by both
    the live evaluate_deny check and the self-test so the two never diverge on the entry shape."""
    graph = cfg.get("graph") if isinstance(cfg, dict) and isinstance(cfg.get("graph"), dict) else {}
    out: set[str] = set()
    for t in graph.get("targets") or []:
        if isinstance(t, str):
            out.add(t)
        elif isinstance(t, dict) and isinstance(t.get("triple"), str):
            out.add(t["triple"])
    return out


def evaluate_deny(cfg: object, audit_ignores: set[str]) -> list[str]:
    """(pure) Growth/relaxation problems in the parsed deny.toml `cfg`, reconciled against the
    cargo-audit ignore set."""
    problems: list[str] = []
    cfg = cfg if isinstance(cfg, dict) else {}
    bans = cfg.get("bans") if isinstance(cfg.get("bans"), dict) else {}
    licenses = cfg.get("licenses") if isinstance(cfg.get("licenses"), dict) else {}
    advisories = cfg.get("advisories") if isinstance(cfg.get("advisories"), dict) else {}
    sources = cfg.get("sources") if isinstance(cfg.get("sources"), dict) else {}
    graph = cfg.get("graph") if isinstance(cfg.get("graph"), dict) else {}

    # [bans]: every forbidden crate still denied; wildcards denied
    denied = set()
    for e in bans.get("deny") or []:
        name = e.get("crate") or e.get("name") if isinstance(e, dict) else (e if isinstance(e, str) else None)
        if name:
            denied.add(name)
    for missing in sorted(FORBIDDEN_CRATES - denied):
        problems.append(f"[bans].deny no longer denies `{missing}` - a socket-opening/updater crate guard "
                        "cannot be silently dropped (T2/T9a)")
    if bans.get("wildcards") != "deny":
        problems.append("[bans].wildcards is not \"deny\" - a wildcard version spec must be rejected")

    # [licenses]: allow-list-only (v2), copyleft never allowed, confidence floor held, no blanket exceptions
    if licenses.get("version") != 2:
        problems.append("[licenses].version is not 2 - v2 is allow-list-only (fail-closed); a v1 config "
                        "could carry a permissive `unlicensed`/`copyleft` escape")
    allow = [a for a in (licenses.get("allow") or []) if isinstance(a, str)]
    for lic in sorted(set(allow) - EXPECTED_LICENSE_ALLOW):
        problems.append(f"[licenses].allow contains `{lic}` which is NOT on the frozen permissive set - "
                        "any new license (a copyleft/non-commercial family such as GPL/AGPL/LGPL/EUPL/OSL/"
                        "CDDL/SSPL/CC-BY-NC, or an unvetted permissive one) must be vetted + added to "
                        "EXPECTED_LICENSE_ALLOW here (L(-1)) with a box-id + Dual-Review note")
    ct = licenses.get("confidence-threshold")
    if not isinstance(ct, (int, float)) or ct < MIN_CONFIDENCE:
        problems.append(f"[licenses].confidence-threshold ({ct!r}) is below the {MIN_CONFIDENCE} floor - "
                        "a low-confidence license detection must fail closed, not silently pass")
    if licenses.get("exceptions"):
        problems.append("[licenses].exceptions is non-empty - a per-crate license exception must be added "
                        "HERE (the frozen expectation) with a box-id + Dual-Review note, never quietly")

    # [advisories]: v2 + yanked deny + ignore reconciliation with cargo-audit
    if advisories.get("version") != 2:
        problems.append("[advisories].version is not 2 - v2 denies vulnerability/unmaintained/unsound/notice "
                        "by default; a v1 config could leave a kind permissive")
    if advisories.get("yanked") != "deny":
        problems.append("[advisories].yanked is not \"deny\" - a yanked crate must hard-fail")
    deny_ignores = _ignore_set(advisories)
    if deny_ignores != audit_ignores:
        only_deny = sorted(deny_ignores - audit_ignores)
        only_audit = sorted(audit_ignores - deny_ignores)
        problems.append(f"advisory ignore sets disagree (cargo-deny only: {only_deny}, cargo-audit only: "
                        f"{only_audit}) - an advisory silenced in one scanner but live in the other is a "
                        "false-green (G18 two-scanner reconciliation); the two ignore sets must be equal")

    # [sources]: unknown denied, crates.io allow-listed
    if sources.get("unknown-registry") != "deny":
        problems.append("[sources].unknown-registry is not \"deny\" - an unknown registry is the "
                        "dependency-confusion surface")
    if sources.get("unknown-git") != "deny":
        problems.append("[sources].unknown-git is not \"deny\"")
    if "https://github.com/rust-lang/crates.io-index" not in (sources.get("allow-registry") or []):
        problems.append("[sources].allow-registry does not list crates.io - the sources check is a no-op "
                        "without a populated allow-list")

    # [graph]: the cargo-deny EVALUATION graph must equal the SHIPPED graph, on TWO axes -
    #   (1) `targets` == the shipped desktop-triple set (scoping prunes deps gated to no listed target;
    #       it narrows ALL four cargo-deny checks - bans/advisories/licenses/sources - so a mobile-only
    #       dep drops out of every one. That is correct for a desktop-only product (those deps ship in
    #       zero artifacts) and CVE coverage of them is retained by cargo-audit, the G17 scanner that
    #       reads the FULL Cargo.lock irrespective of [graph].targets - the two-scanner backstop);
    #   (2) `all-features` stays true (off -> cargo-deny evaluates only DEFAULT features, so a banned
    #       crate pulled in solely by a non-default feature would escape the [bans] egress check).
    targets = _graph_targets(cfg)
    if targets != EXPECTED_GRAPH_TARGETS:
        missing = sorted(EXPECTED_GRAPH_TARGETS - targets)
        extra = sorted(targets - EXPECTED_GRAPH_TARGETS)
        problems.append(
            f"[graph].targets must equal the frozen shipped desktop-triple set (spec §03 'Target "
            f"triples') - missing {missing} (a DROPPED shipped triple blinds the live cargo-deny to an "
            f"on-that-triple network/copyleft dep = fail-OPEN), extra {extra} (a NON-shipped triple "
            f"re-masks tauri's mobile-only reqwest/hyper back into scope). The [graph] scope is "
            f"security-load-bearing once `targets` is set; a change is an L(-1) edit with a box-id + "
            f"Dual-Review note (like FORBIDDEN_CRATES)")
    if graph.get("all-features") is not True:
        problems.append("[graph].all-features must be `true` - with it off/absent cargo-deny evaluates "
                        "only DEFAULT features, so a banned crate (reqwest/hyper/...) reachable only via "
                        "a non-default feature would ESCAPE the [bans] egress check; frozen on (L(-1))")
    return problems


def evaluate_vet(cfg: object) -> list[str]:
    """(pure) Problems in the parsed supply-chain/config.toml `cfg`: the >=2-import-source floor + the
    exemption growth-guard."""
    problems: list[str] = []
    cfg = cfg if isinstance(cfg, dict) else {}
    imports = cfg.get("imports") if isinstance(cfg.get("imports"), dict) else {}
    # count DISTINCT url VALUES (not table keys) - two keys pointing at the SAME url give zero
    # redundancy, so a single compromised DB could still single-handedly vouch a crate
    urls = {v["url"] for v in imports.values()
            if isinstance(v, dict) and isinstance(v.get("url"), str) and v["url"]}
    if len(urls) < MIN_IMPORT_SOURCES:
        problems.append(f"supply-chain/config.toml declares {len(urls)} DISTINCT import URL(s) < the "
                        f"required {MIN_IMPORT_SOURCES} - one compromised audit DB could single-handedly "
                        "vouch a crate; keep >=2 distinct [imports.*] source URLs")
    exemptions = cfg.get("exemptions") if isinstance(cfg.get("exemptions"), dict) else {}
    total = sum(len(v) if isinstance(v, list) else 1 for v in exemptions.values())
    if total > EXPECTED_EXEMPTION_COUNT:
        problems.append(f"cargo-vet exemption set holds {total} entr(ies) > the expected "
                        f"{EXPECTED_EXEMPTION_COUNT} - growth must raise EXPECTED_EXEMPTION_COUNT here with a "
                        "box-id + Dual-Review note (symmetry with the G2 allowlist)")
    return problems


def _tauri_plugin_drift(lock_text: str) -> list[str]:
    """(pure) §0.10 plugin-surface PRESENCE check over Cargo.lock — the 2nd, independent structural
    enforcer of the deny-all-tauri-plugins-except-allowlist rule (plan-lint check 13 is the 1st; this one
    needs no cargo binary). Every `tauri-plugin-*` crate in the lock must be on the §0.10-granted allowlist
    OR the forced-transitive-inert set. (The `.plugin()`-registration + fs: capability surfaces are
    plan-lint check 13's and G47's respectively — not re-checked here; this guards LOCK PRESENCE only.)"""
    problems: list[str] = []
    for mt in re.finditer(r'name = "tauri-plugin-([a-z-]+)"', lock_text):
        name = mt.group(1)
        if name not in TAURI_PLUGIN_ALLOWLIST and name not in TAURI_PLUGIN_INERT:
            problems.append(f"tauri-plugin-{name} is in Cargo.lock but on neither the §0.10 granted allowlist "
                            f"{sorted(TAURI_PLUGIN_ALLOWLIST)} nor the forced-transitive-inert set "
                            f"{sorted(TAURI_PLUGIN_INERT)} — an unexpected Tauri plugin surface (T2/T2c)")
    return problems


def _tauri_plugin_checks() -> list[str]:
    """Run the structural tauri-plugin PRESENCE scan when a Cargo.lock exists (root OR src-tauri/);
    skip-with-notice when no workspace yet (the P0 pre-P1 posture — plan-lint check 13 also skips then)."""
    lock = next((p for p in CARGO_LOCK_CANDIDATES if p.is_file()), None)
    if lock is None:
        print("[G18] no Cargo.lock yet (lands in P1) - skipping the tauri-plugin presence scan "
              "(plan-lint check 13 + this 2nd enforcer both fail-closed the moment the lock exists)")
        return []
    return _tauri_plugin_drift(lock.read_text(encoding="utf-8", errors="replace"))


def _load(path: Path) -> object:
    return tomllib.loads(path.read_text(encoding="utf-8"))


def _workspace_state(lock_candidates=CARGO_LOCK_CANDIDATES, toml_candidates=CARGO_TOML_CANDIDATES):
    """(pure-ish) Resolve the Rust workspace state from the candidate manifest/lock paths:
      * ('ready', manifest, lock)   - a Cargo.lock was found -> run the live tier;
      * ('lock-missing', manifest)  - a Cargo.toml exists but NO lock at any candidate -> FAIL (a
                                      layout mismatch / un-generated lock must redden main, never
                                      silently disarm the live cargo-deny/vet tier);
      * ('absent',)                 - no workspace yet (the P0 pre-P1 posture) -> skip with a notice."""
    lock = next((p for p in lock_candidates if p.is_file()), None)
    toml = next((p for p in toml_candidates if p.is_file()), None)
    if lock is not None:
        return ("ready", toml or lock.parent / "Cargo.toml", lock)
    if toml is not None:
        return ("lock-missing", toml)
    return ("absent",)


def _live_checks() -> list[str]:
    """Run the LIVE cargo-deny / cargo-vet binaries once the workspace lock exists (root OR src-tauri/);
    target-absent + skipped until then, but FAIL-CLOSED if a manifest exists without a lock."""
    state = _workspace_state()
    if state[0] == "absent":
        print("[G18] no Cargo workspace yet (lands in P1) - skipping live `cargo deny`/`cargo vet` "
              "(structural policy guard still enforced); fail-closed the moment the lockfile exists")
        return []
    if state[0] == "lock-missing":
        return [f"a Cargo manifest ({state[1]}) exists but no Cargo.lock was found at any candidate "
                f"location {[str(p) for p in CARGO_LOCK_CANDIDATES]} - the live supply-chain tier cannot "
                "run; generate/commit the lockfile (do not let G18 silently skip on a layout mismatch)"]
    _, manifest, _lock = state
    problems: list[str] = []
    manifest_dir = manifest.parent
    if shutil.which("cargo-deny"):
        r = subprocess.run(["cargo", "deny", "--manifest-path", str(manifest), "check"],
                           capture_output=True, text=True, encoding="utf-8", errors="replace")
        if r.returncode != 0:
            problems.append("`cargo deny check` failed:\n" + (r.stderr or r.stdout))
    else:
        print("[G18] a Cargo.lock exists but `cargo-deny` is not installed in this plane - the live "
              "cargo-deny check is skipped here (the frozen deny.toml policy stays fail-closed; the live "
              "binary enforces at L1/L2 + the equipped Rust CI supply-chain leg)")
    if shutil.which("cargo-vet"):
        r = subprocess.run(["cargo", "vet", "--locked", "check"], capture_output=True, text=True, encoding="utf-8", errors="replace", cwd=manifest_dir)
        if r.returncode != 0:
            problems.append("`cargo vet --locked check` failed:\n" + (r.stderr or r.stdout))
        if not VET_IMPORTS.is_file():
            problems.append("supply-chain/imports.lock is missing - the committed trust DB must exist "
                            "(no live-registry trust at gate time)")
    else:
        print("[G18b] a Cargo.lock exists but `cargo-vet` is not installed in this plane - the live "
              "cargo-vet check is skipped here (the frozen supply-chain/config.toml policy stays "
              "fail-closed; the live binary enforces at L1/L2 + the equipped Rust CI supply-chain leg)")
    return problems


def _parse_ver(v: str):
    """(release: tuple[int,int,int], pre: tuple) for a 'X.Y.Z[-pre][+build]' version, comparable so a
    release outranks its pre-releases and numeric pre-segments sort numerically + below alphanumerics
    (semver §11). None if the release core is not three ints (the caller fails closed)."""
    core = v.strip().split("+", 1)[0]            # +build metadata does not affect precedence
    rel, _, pre = core.partition("-")
    parts = rel.split(".")
    if len(parts) != 3 or not all(p.isdigit() for p in parts):
        return None
    pre_ids = []
    for ident in (pre.split(".") if pre else []):
        pre_ids.append((0, int(ident)) if ident.isdigit() else (1, ident))  # numeric < alphanumeric
    return (tuple(int(p) for p in parts), tuple(pre_ids))


def _version_ge(have: str, floor: str):
    """have >= floor by semver precedence; None if either is unparseable (caller fails closed)."""
    a, b = _parse_ver(have), _parse_ver(floor)
    if a is None or b is None:
        return None
    (arel, apre), (brel, bpre) = a, b
    if arel != brel:
        return arel > brel
    if not apre and not bpre:
        return True                  # equal release, neither a pre-release
    if not apre:
        return True                  # have is the release, floor is a pre -> have outranks
    if not bpre:
        return False                 # have is a pre, floor is the release -> have is lower
    return apre >= bpre              # both pre-releases: semver tuple precedence


def _pinned_floor_assertion() -> list[str]:
    """§0.8 pinned-floor (P1.59): each PINNED_FLOORS crate must be in Cargo.lock at >= its floor. A listed
    crate ABSENT from the lock is a FAIL (a relied-upon dep vanished); an unparseable version is a FAIL
    (fail-closed). Target-absent (no lock yet) returns clean - the live tier already skip-noticed."""
    lock = next((p for p in CARGO_LOCK_CANDIDATES if p.is_file()), None)
    if lock is None:
        return []
    try:
        data = tomllib.loads(lock.read_text(encoding="utf-8"))
    except tomllib.TOMLDecodeError as e:
        return [f"Cargo.lock is not valid TOML ({e}) - cannot assert the §0.8 pinned floors (fail-closed)"]
    versions: dict[str, list[str]] = {}
    for pkg in data.get("package") or []:
        if isinstance(pkg, dict) and isinstance(pkg.get("name"), str) and isinstance(pkg.get("version"), str):
            versions.setdefault(pkg["name"], []).append(pkg["version"])
    problems: list[str] = []
    for crate, floor in sorted(PINNED_FLOORS.items()):
        have = versions.get(crate)
        if not have:
            problems.append(f"§0.8 floor crate `{crate}` (>= {floor}) is not in Cargo.lock - a relied-upon "
                            "dependency vanished; restore it or remove the floor row HERE (L(-1)) with a box-id")
            continue
        # Cargo.lock can carry MULTIPLE versions of one crate (deny.toml multiple-versions="warn"); the floor
        # is satisfied if ANY present copy is >= floor (our code can resolve to it). Red only when EVERY copy
        # is below floor (a genuine drift) - and fail closed if a version is unparseable.
        ges = [_version_ge(v, floor) for v in have]
        if any(g is True for g in ges):
            continue
        if any(g is None for g in ges):
            problems.append(f"§0.8 floor crate `{crate}`: an unparseable version among {sorted(have)} (floor "
                            f"{floor!r}) - failing closed (a floor that cannot be evaluated is not enforced)")
        else:
            problems.append(f"§0.8 floor crate `{crate}` is present only at {sorted(have)} < its pinned floor "
                            f"{floor} - a drift below the relied-upon API floor; bump the dep or lower the "
                            "floor HERE (L(-1)) with a box-id + Dual-Review note")
    return problems


def main() -> int:
    for path in (DENY, VET_CONFIG):
        if not path.is_file():
            print(f"[G18] {path} missing", file=sys.stderr)
            return 2
    try:
        deny_cfg = _load(DENY)
        vet_cfg = _load(VET_CONFIG)
    except tomllib.TOMLDecodeError as e:
        print(f"[G18] config is not valid TOML: {e}", file=sys.stderr)
        return 2
    audit_ignores: set[str] = set()
    if AUDIT_TOML.is_file():
        try:
            audit_ignores = _ignore_set(_load(AUDIT_TOML).get("advisories"))
        except tomllib.TOMLDecodeError as e:
            print(f"[G18] {AUDIT_TOML} is not valid TOML: {e}", file=sys.stderr)
            return 2

    problems = (evaluate_deny(deny_cfg, audit_ignores) + evaluate_vet(vet_cfg)
                + _tauri_plugin_checks() + _live_checks() + _pinned_floor_assertion())
    if problems:
        for p in problems:
            fail(p)
        return 1
    print(f"[G18] supply-chain policy OK ({len(FORBIDDEN_CRATES)} forbidden crates denied; copyleft "
          f"excluded; allow-list-only licenses; yanked=deny; {len(_ignore_set(deny_cfg.get('advisories')))} "
          f"advisory ignore(s) reconciled with cargo-audit; >={MIN_IMPORT_SOURCES} cargo-vet import "
          f"sources; <= {EXPECTED_EXEMPTION_COUNT} exemption(s); every tauri-plugin granted or "
          f"forced-inert-fs; {len(PINNED_FLOORS)} §0.8 floor crate(s) >= floor)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
