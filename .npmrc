# .npmrc — JS/WebView supply-chain lockdown (G18c registry pin + G18d lifecycle-script posture).
# Authored P0.3.8; the live pnpm-lock-URL guard + the onlyBuiltDependencies allowlist activate in P1
# once the pnpm workspace + lockfile exist. The WebView is the ENTIRE T2 attack surface, so its supply
# chain matches the Rust-side discipline (the JS analogue of deny.toml [sources] + [bans]).
# L(-1) security-critical (scripts/l-neg1-files.toml, G71) — structurally guarded by
# scripts/check-js-supply-chain.

# G18c — pin the registry: every dependency resolves from the public npm registry, nowhere else
# (dependency-confusion / source-substitution defence; check-js-supply-chain asserts every
# pnpm-lock.yaml resolution URL is from this origin once the lockfile lands).
registry=https://registry.npmjs.org/

# G18d — install-lifecycle-script lockdown. pnpm 10 already blocks dependency build/lifecycle scripts
# by default (only an explicit onlyBuiltDependencies allowlist may run them); these pin that posture so
# a malicious dep cannot run arbitrary code via postinstall the moment `pnpm install` runs in CI (which
# holds the signing secrets at release time).
enable-pre-post-scripts=false
unsafe-perm=false

# G18a (JS analogue) — CI installs against the committed lockfile; a drifted lockfile fails rather than
# silently resolving a different graph than the audited/SBOM'd one.
frozen-lockfile=true
